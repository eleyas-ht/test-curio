# ─────────────────────────────────────────────────────────────
#  Shopify Storefront API — SERVER-SIDE secrets (copy to .env).
#  No PUBLIC_ prefix => kept on the server only, never shipped
#  to the browser. The storefront proxies all Shopify calls via
#  same-origin /api/* routes using the private token.
# ─────────────────────────────────────────────────────────────

# Your store's myshopify domain, e.g. your-shop.myshopify.com
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com

# Storefront API private (delegate) access token — server only.
# Header used: Shopify-Storefront-Private-Token
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx

# Pin the API version. Do not use unversioned URLs.
SHOPIFY_API_VERSION=2026-04

# ─────────────────────────────────────────────────────────────
#  Customer Account API — customer login (OAuth 2.0 + PKCE).
#  Enable "New customer accounts" in Settings → Customer accounts,
#  then open the Headless/Hydrogen channel → Customer Account API.
#  In "Application setup" register ALL THREE (use your public HTTPS
#  origin — e.g. a tunnel host; Shopify rejects http and localhost):
#    Callback URI(s):     https://YOUR_HOST/account/authorize
#    JavaScript origin(s): https://YOUR_HOST   (validated on token exchange)
#    Logout URI:          https://YOUR_HOST
#  The app derives the origin from X-Forwarded-Proto/Host, so it works
#  behind tunnels automatically (see src/lib/shopify/customer/origin.ts).
# ─────────────────────────────────────────────────────────────

# Customer Account API Client ID (from the API settings page).
CUSTOMER_ACCOUNT_API_CLIENT_ID=shp_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your store's numeric Shop ID (shown in the Customer Account API settings).
SHOPIFY_SHOP_ID=000000000000

# Customer Account API version (separate from the Storefront version).
CUSTOMER_ACCOUNT_API_VERSION=2025-01

# ─────────────────────────────────────────────────────────────
#  Instagram Basic Display API — optional, for the Instagram section.
#  Only required when INSTAGRAM.mode is set to 'api' in
#  src/config/instagram.ts. Leave blank to use custom/manual posts.
#
#  How to get a long-lived token (~60 days):
#  1. Create a Meta App at developers.facebook.com
#  2. Add the "Instagram Basic Display" product
#  3. Generate a short-lived token under Instagram → Basic Display
#  4. Exchange it for a long-lived token:
#     GET https://graph.instagram.com/access_token
#       ?grant_type=ig_exchange_token
#       &client_secret=<APP_SECRET>
#       &access_token=<SHORT_LIVED_TOKEN>
#  5. Refresh before expiry:
#     GET https://graph.instagram.com/refresh_access_token
#       ?grant_type=ig_refresh_token
#       &access_token=<LONG_LIVED_TOKEN>
# ─────────────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────
#  Newsletter — provider credentials.
#  The active provider is selected in src/config/newsletter.ts.
#
#  'shopify' provider (default) — Admin API token required.
#  How to create one:
#  1. Shopify Admin → Settings → Apps and sales channels
#  2. Develop apps → Create an app → name it e.g. "Newsletter"
#  3. Configure Admin API scopes → enable: write_customers, read_customers
#  4. Install the app → copy the "Admin API access token" (shown once)
#  5. Paste it below.
# ─────────────────────────────────────────────────────────────

# 'shopify' provider — Admin API access token (write_customers scope).
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx

# 'klaviyo' provider — private API key + list ID.
KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=

# 'mailchimp' provider — API key, audience/list ID, and data-center prefix.
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_DC=

# 'webhook' provider — target URL + optional Bearer secret.
NEWSLETTER_WEBHOOK_URL=
NEWSLETTER_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
#  Judge.me Reviews — product ratings on the PDP.
#  Get your API token from your Judge.me dashboard:
#  Judge.me Admin → Settings → Integrations → API
# ─────────────────────────────────────────────────────────────
JUDGEME_API_TOKEN=
