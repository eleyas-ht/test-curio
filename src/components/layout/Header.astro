---
// ============================================================
//  Header / Masthead
//
//  Content sources (in priority order):
//    1. Shopify "main-menu" (up to 3 levels deep)
//    2. FALLBACK_NAV in ~/config/nav.ts
//
//  Dynamic fields managed via config:
//    • Logo label  → SITE.name + SITE.brandSuffix
//    • Issue label → SITE.issue
//    • Nav links   → Shopify main-menu → FALLBACK_NAV
//
//  Dropdown menus: rendered when a top-level item has children.
//  Mega menus:     rendered when children also have children.
//  Mobile menu:    slide-in panel with accordion sub-nav.
// ============================================================
import { getMenu } from '~/lib/shopify';
import { CUSTOM_NAV, NAV_SOURCE, type NavItem } from '~/config/nav';
import { SITE } from '~/config/site';
import PredictiveSearch from '~/components/layout/PredictiveSearch.astro';

// ── URL helpers ─────────────────────────────────────────────

/** Strip domain from an absolute Shopify URL → relative path. */
function toPath(url: string): string {
  try {
    const u = new URL(url);
    return u.pathname + (u.search || '');
  } catch {
    return url.startsWith('/') ? url : `/${url}`;
  }
}

/**
 * Map a Shopify menu item URL to this storefront's routes.
 *
 * Shopify returns absolute myshopify.com URLs; toPath() extracts
 * the pathname which maps 1-to-1 to our routes for COLLECTION,
 * PRODUCT, PAGE, BLOG, ARTICLE, SHOP_POLICY, and HTTP types.
 * The only overrides needed are for CATALOG (→ /products) and
 * FRONTPAGE (→ /) which use Shopify-internal handles.
 */
function navUrl(title: string, rawUrl: string, type?: string): string {
  const t = title.trim().toLowerCase();
  if (type === 'CATALOG' || t === 'shop' || t === 'shop all') return '/products';
  if (type === 'FRONTPAGE' || t === 'home') return '/';
  if (type === 'SEARCH') return '/search';
  return toPath(rawUrl);
}

// ── Recursive Shopify → NavItem mapper ──────────────────────

function mapItem(item: { title: string; url: string; type: string; items?: typeof item[] }): NavItem {
  return {
    title: item.title,
    url: navUrl(item.title, item.url, item.type),
    sale: /sale/i.test(item.title),
    items: item.items?.length ? item.items.map(mapItem) : undefined,
  };
}

// ── Resolve nav: Shopify or custom ──────────────────────────

let nav: NavItem[] = CUSTOM_NAV;

if (NAV_SOURCE === 'shopify') {
  try {
    const menu = await getMenu('main-menu');
    if (menu?.items?.length) {
      nav = menu.items.map(mapItem);
    }
  } catch {
    /* keep CUSTOM_NAV as fallback on API error */
  }
}

// ── Issue label: wrap the number in <em> for italic styling ─

function issueHtml(issue: string): string {
  return issue.replace(/^(.*?\s+)(\d+)(\s*.*)$/, '$1<em>$2</em>$3');
}
---

<header class="header" id="header">
  <div class="container header-row">
    <div class="header-left">
      <span class="header-issue" set:html={issueHtml(SITE.issue)} />
    </div>
    <a href="/" class="header-brand">{SITE.name}<sup>{SITE.brandSuffix}</sup></a>
    <div class="header-right">
      {/* PredictiveSearch renders its own trigger button + overlay */}
      <PredictiveSearch />
      <a class="header-icon" href="/account" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6">
          <circle cx="12" cy="8" r="4" />
          <path d="M4 21c0-4 4-6 8-6s8 2 8 6" />
        </svg>
      </a>
      <button class="header-icon" id="wish-btn" aria-label="Wishlist">
        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
        </svg>
        <span class="wish-count-badge" id="wish-count" style="display:none;">0</span>
      </button>
      <button class="header-icon" aria-label="Cart" id="cart-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6">
          <path d="M5 7h14l-1.5 11a2 2 0 0 1-2 1.7H8.5a2 2 0 0 1-2-1.7L5 7Z" />
          <path d="M9 7V5a3 3 0 0 1 6 0v2" />
        </svg>
        <span class="cart-count" id="cart-count" style="display:none;">0</span>
      </button>
      <button class="header-icon menu-toggle" aria-label="Menu" id="menu-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  {/* ── Desktop nav ─────────────────────────────────────── */}
  <nav class="header-nav container">
    {nav.map((item) => {
      const hasChildren = Boolean(item.items?.length);
      const hasMega = hasChildren && item.items!.some((sub) => Boolean(sub.items?.length));
      const saleStyle = item.sale ? 'color:var(--clay);' : undefined;
      const saleClass = item.sale ? 'sale' : undefined;

      if (!hasChildren) {
        return (
          <a href={item.url} style={saleStyle} class={saleClass}>
            {item.title}
          </a>
        );
      }

      return (
        <div class="nav-item">
          <a href={item.url} style={saleStyle} class={saleClass}>
            {item.title}
            <svg class="nav-chevron" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </a>

          {hasMega ? (
            /* Mega menu — items whose children also have children */
            <div class="nav-mega" role="region" aria-label={`${item.title} submenu`}>
              <div class="nav-mega-inner">
                {item.items!.map((sub) => (
                  <div class="nav-mega-col">
                    <a
                      href={sub.url}
                      class={`nav-mega-heading${sub.sale ? ' sale' : ''}`}
                      style={sub.sale ? 'color:var(--clay);' : undefined}
                    >
                      {sub.title}
                    </a>
                    {sub.items?.map((deep) => (
                      <a
                        href={deep.url}
                        class={`nav-mega-link${deep.sale ? ' sale' : ''}`}
                        style={deep.sale ? 'color:var(--clay);' : undefined}
                      >
                        {deep.title}
                      </a>
                    ))}
                  </div>
                ))}
              </div>
            </div>
          ) : (
            /* Dropdown — items with one level of children */
            <div class="nav-dropdown" role="region" aria-label={`${item.title} submenu`}>
              {item.items!.map((sub) => (
                <a
                  href={sub.url}
                  class={sub.sale ? 'sale' : undefined}
                  style={sub.sale ? 'color:var(--clay);' : undefined}
                >
                  {sub.title}
                </a>
              ))}
            </div>
          )}
        </div>
      );
    })}
  </nav>
</header>

{/* Mobile menu backdrop */}
<div class="menu-backdrop" id="menu-backdrop"></div>

{/* ── Mobile slide-in menu ──────────────────────────────── */}
<aside class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation">
  <div class="mobile-menu-close">
    <span style="font-family:var(--font-serif);font-size:24px;">{SITE.name}</span>
    <button id="menu-close" aria-label="Close menu">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
        <path d="m6 6 12 12M6 18 18 6" />
      </svg>
    </button>
  </div>
  <nav>
    {nav.map((item, i) => {
      const hasChildren = Boolean(item.items?.length);
      const saleStyle = item.sale ? 'color:var(--clay);' : undefined;

      if (!hasChildren) {
        return <a href={item.url} style={saleStyle}>{item.title}</a>;
      }

      const panelId = `mob-panel-${i}`;
      return (
        <div class="mob-nav-group">
          <div class="mob-nav-top">
            <a href={item.url} style={saleStyle}>{item.title}</a>
            <button
              class="mob-acc-btn"
              aria-expanded="false"
              data-target={panelId}
              aria-label={`Expand ${item.title}`}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </button>
          </div>
          <div class="mob-acc-panel" id={panelId}>
            {item.items!.map((sub) => {
              const subHasChildren = Boolean(sub.items?.length);
              if (!subHasChildren) {
                return (
                  <a href={sub.url} class="mob-sub-link" style={sub.sale ? 'color:var(--clay);' : undefined}>
                    {sub.title}
                  </a>
                );
              }
              return (
                <Fragment>
                  <span class="mob-sub-heading">{sub.title}</span>
                  {sub.items!.map((deep) => (
                    <a href={deep.url} class="mob-sub-link mob-deep-link" style={deep.sale ? 'color:var(--clay);' : undefined}>
                      {deep.title}
                    </a>
                  ))}
                </Fragment>
              );
            })}
          </div>
        </div>
      );
    })}
  </nav>
</aside>

<style is:global>
  /* ── Mobile menu backdrop ──────────────────────────────── */
  .menu-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(17, 17, 17, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 210;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--t-base, 320ms) var(--ease, ease),
                visibility var(--t-base, 320ms) var(--ease, ease);
  }

  .menu-backdrop.open {
    opacity: 1;
    visibility: visible;
  }

  /* ── Desktop nav: nav-item wrapper ─────────────────────── */
  .nav-item {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  /* The top-level anchor inside a nav-item keeps all existing
     .header-nav a styles (underline animation, hover colour).
     We just add flex so the chevron sits inline. */
  .nav-item > a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .nav-chevron {
    opacity: 0.45;
    transition: transform var(--t-fast, 200ms) var(--ease, ease),
                opacity var(--t-fast, 200ms) var(--ease, ease);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .nav-item:hover .nav-chevron,
  .nav-item:focus-within .nav-chevron {
    transform: rotate(180deg);
    opacity: 0.9;
  }

  /* ── Shared dropdown / mega panel base ─────────────────── */
  .nav-dropdown,
  .nav-mega {
    position: absolute;
    top: calc(100% + 12px);
    background: var(--cream, #f7f2ea);
    border: 1px solid var(--sand, #e7d8c5);
    box-shadow: 0 16px 48px rgba(17, 17, 17, 0.10);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 180ms var(--ease, ease),
                transform 180ms var(--ease, ease),
                visibility 180ms;
    z-index: 90;
  }

  /*
   * Invisible bridge that covers the 12 px gap between the nav
   * trigger and the panel. Hovering over it counts as hovering
   * over .nav-dropdown / .nav-mega (a descendant of .nav-item),
   * so :hover on .nav-item stays true and the panel stays open.
   */
  .nav-dropdown::before,
  .nav-mega::before {
    content: '';
    position: absolute;
    top: -13px;    /* 12px gap + 1px overhang */
    left: -8px;
    right: -8px;
    height: 14px;
  }

  .nav-item:hover .nav-dropdown,
  .nav-item:focus-within .nav-dropdown,
  .nav-item:hover .nav-mega,
  .nav-item:focus-within .nav-mega {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* ── Dropdown (1 level deep) ────────────────────────────── */
  .nav-dropdown {
    left: 0;
    min-width: 210px;
    padding: 10px 0;
  }

  .nav-dropdown a {
    display: block;
    padding: 9px 22px;
    font-family: var(--font-sans, sans-serif);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.005em;
    color: var(--ink, #111);
    white-space: nowrap;
    /* override .header-nav a rules that don't apply inside dropdowns */
    position: static;
    transition: color 160ms, background 160ms;
  }

  .nav-dropdown a::after {
    display: none !important;
  }

  .nav-dropdown a:hover {
    color: var(--clay, #9a6b4f);
    background: rgba(231, 216, 197, 0.35);
  }

  /* ── Mega menu (2 levels deep) ──────────────────────────── */
  .nav-mega {
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    width: min(900px, 88vw);
  }

  /* Mega menu needs translateX preserved when overriding the shared show rule. */
  .nav-item:hover .nav-mega,
  .nav-item:focus-within .nav-mega {
    transform: translateX(-50%) translateY(0);
  }

  .nav-mega-inner {
    display: flex;
    padding: 28px 32px;
    gap: 0;
  }

  .nav-mega-col {
    flex: 1;
    min-width: 130px;
    padding: 0 24px;
    border-right: 1px solid var(--sand, #e7d8c5);
  }

  .nav-mega-col:first-child {
    padding-left: 0;
  }

  .nav-mega-col:last-child {
    border-right: none;
    padding-right: 0;
  }

  .nav-mega-heading {
    display: block;
    font-family: var(--font-sans, sans-serif);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink, #111);
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--sand, #e7d8c5);
    position: static;
    transition: color 150ms;
  }

  .nav-mega-heading::after {
    display: none !important;
  }

  .nav-mega-heading:hover {
    color: var(--clay, #9a6b4f);
  }

  .nav-mega-link {
    display: block;
    padding: 5px 0;
    font-family: var(--font-sans, sans-serif);
    font-size: 13.5px;
    font-weight: 400;
    color: var(--muted, #6f6a64);
    white-space: nowrap;
    position: static;
    transition: color 150ms;
  }

  .nav-mega-link::after {
    display: none !important;
  }

  .nav-mega-link:hover {
    color: var(--ink, #111);
  }

  /* ── Mobile accordion ───────────────────────────────────── */
  .mob-nav-group {
    border-bottom: 1px solid var(--sand, #e7d8c5);
  }

  /* The top row shares the same border the old `nav a` had. */
  .mob-nav-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mob-nav-top > a {
    flex: 1;
    border-bottom: none !important;
  }

  .mob-acc-btn {
    width: 38px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted, #6f6a64);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: color 180ms;
  }

  .mob-acc-btn svg {
    transition: transform 220ms var(--ease, ease);
  }

  .mob-acc-btn[aria-expanded="true"] {
    color: var(--clay, #9a6b4f);
  }

  .mob-acc-btn[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }

  .mob-acc-panel {
    display: none;
    padding: 2px 0 14px;
  }

  .mob-acc-panel.open {
    display: block;
  }

  .mob-sub-link {
    display: block;
    padding: 9px 0;
    font-family: var(--font-serif, serif);
    font-size: 19px;
    color: var(--muted, #6f6a64);
    border-bottom: none !important;
    transition: color 150ms;
  }

  .mob-sub-link::after {
    display: none !important;
  }

  .mob-sub-link:hover {
    color: var(--ink, #111);
  }

  .mob-deep-link {
    padding-left: 16px;
    font-size: 16px;
  }

  .mob-sub-heading {
    display: block;
    font-family: var(--font-sans, sans-serif);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted-light, #a09a92);
    padding: 12px 0 4px;
  }

  /* Hide desktop dropdowns/mega menus at mobile breakpoint */
  @media (max-width: 760px) {
    .nav-dropdown,
    .nav-mega {
      display: none;
    }
  }
</style>

<script>
  import { $cart, openCart, initCart } from '~/stores/cart';
  import { $wishlist, initWishlist, openWishlist } from '~/stores/wishlist';

  // Cart badge + open drawer.
  void initCart();
  const countEl = document.getElementById('cart-count');
  $cart.subscribe((c) => {
    const n = c?.totalQuantity ?? 0;
    if (countEl) {
      countEl.textContent = String(n);
      countEl.style.display = n > 0 ? '' : 'none';
    }
  });
  document.getElementById('cart-btn')?.addEventListener('click', () => openCart());

  // Wishlist badge + open drawer.
  initWishlist();
  const wishCountEl = document.getElementById('wish-count');
  $wishlist.subscribe((items) => {
    const n = items.length;
    if (wishCountEl) {
      wishCountEl.textContent = String(n);
      wishCountEl.style.display = n > 0 ? '' : 'none';
    }
  });
  document.getElementById('wish-btn')?.addEventListener('click', () => openWishlist());

  // Mobile menu open / close.
  const mobileMenu = document.getElementById('mobile-menu');
  const menuBackdrop = document.getElementById('menu-backdrop');

  const openMenu = () => {
    mobileMenu?.classList.add('open');
    menuBackdrop?.classList.add('open');
    document.body.style.overflow = 'hidden';
  };
  const closeMenu = () => {
    mobileMenu?.classList.remove('open');
    menuBackdrop?.classList.remove('open');
    document.body.style.overflow = '';
  };

  document.getElementById('menu-btn')?.addEventListener('click', openMenu);
  document.getElementById('menu-close')?.addEventListener('click', closeMenu);
  menuBackdrop?.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });

  // Mobile accordion for nested nav items.
  document.querySelectorAll<HTMLButtonElement>('.mob-acc-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const targetId = btn.getAttribute('data-target');
      if (targetId) {
        document.getElementById(targetId)?.classList.toggle('open', !expanded);
      }
    });
  });
</script>
