---
// StyleGuideBody.astro — Design system reference page.
---

<!-- Hero -->
<section class="sg-hero">
  <div class="container">
    <div class="sg-hero-inner">
      <div>
        <span class="sg-eyebrow"><span class="sg-eyebrow-dot"></span>Design System</span>
        <h1 class="sg-hero-title">The <em>visual</em> language.</h1>
        <p class="sg-hero-lead">Color, type, and component tokens that define the Curio editorial aesthetic. A living reference for designers and engineers building on this theme.</p>
      </div>
      <div class="sg-hero-meta">
        <div class="sg-meta-item">
          <span class="sg-meta-label">Version</span>
          <span class="sg-meta-value"><code>1.3.0</code></span>
        </div>
        <div class="sg-meta-item">
          <span class="sg-meta-label">Stack</span>
          <span class="sg-meta-value">Astro 6 + Tailwind v4</span>
        </div>
        <div class="sg-meta-item">
          <span class="sg-meta-label">Fonts</span>
          <span class="sg-meta-value">Newsreader + Inter</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Sticky nav -->
<nav class="sg-nav" aria-label="Style guide sections">
  <div class="container">
    <div class="sg-nav-inner">
      <a href="#sg-colors" class="sg-nav-link">Colors</a>
      <a href="#sg-typography" class="sg-nav-link">Typography</a>
      <a href="#sg-buttons" class="sg-nav-link">Buttons</a>
      <a href="#sg-forms" class="sg-nav-link">Forms</a>
      <a href="#sg-components" class="sg-nav-link">Components</a>
      <a href="#sg-motion" class="sg-nav-link">Motion</a>
    </div>
  </div>
</nav>

<!-- 1. Colors -->
<section class="sg-section" id="sg-colors">
  <div class="container">
    <div class="sg-section-head">
      <h2 class="sg-section-title">Color Palette</h2>
      <span class="sg-section-num">01</span>
    </div>
    <p class="sg-section-desc">CSS custom properties set on <code class="sg-inline-code">:root</code> in <code class="sg-inline-code">editorial.css</code>. Reference these tokens in all UI — never raw hex values.</p>

    <div class="sg-sub-title">Core Palette</div>
    <div class="sg-color-grid">
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#111111;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--ink</span>
          <span class="sg-swatch-hex">#111111</span>
          <span class="sg-swatch-role">Primary text, headings</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#F7F2EA;border-bottom:1px solid #E7D8C5;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--cream</span>
          <span class="sg-swatch-hex">#F7F2EA</span>
          <span class="sg-swatch-role">Page background</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#EFE8DC;border-bottom:1px solid #E7D8C5;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--cream-deep</span>
          <span class="sg-swatch-hex">#EFE8DC</span>
          <span class="sg-swatch-role">Section backgrounds</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#FFFCF7;border-bottom:1px solid #E7D8C5;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--warm-white</span>
          <span class="sg-swatch-hex">#FFFCF7</span>
          <span class="sg-swatch-role">Cards, modals, inputs</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#9A6B4F;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--clay</span>
          <span class="sg-swatch-hex">#9A6B4F</span>
          <span class="sg-swatch-role">Accent, links, highlights</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#7A523B;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--clay-deep</span>
          <span class="sg-swatch-hex">#7A523B</span>
          <span class="sg-swatch-role">Accent hover states</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#2A211C;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--cocoa</span>
          <span class="sg-swatch-hex">#2A211C</span>
          <span class="sg-swatch-role">Dark sections, CTA bg</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#6F6A64;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--muted</span>
          <span class="sg-swatch-hex">#6F6A64</span>
          <span class="sg-swatch-role">Body text, descriptors</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#A09A92;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--muted-light</span>
          <span class="sg-swatch-hex">#A09A92</span>
          <span class="sg-swatch-role">Placeholders, captions</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#E7D8C5;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--sand</span>
          <span class="sg-swatch-hex">#E7D8C5</span>
          <span class="sg-swatch-role">Borders, dividers</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#D9C7B0;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--sand-deep</span>
          <span class="sg-swatch-hex">#D9C7B0</span>
          <span class="sg-swatch-role">Strong borders, inputs</span>
        </div>
      </div>
      <div class="sg-swatch">
        <div class="sg-swatch-chip" style="background:#6C7A89;"></div>
        <div class="sg-swatch-info">
          <span class="sg-swatch-name">--dusty-blue</span>
          <span class="sg-swatch-hex">#6C7A89</span>
          <span class="sg-swatch-role">Info states, code</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 2. Typography -->
<section class="sg-section" id="sg-typography">
  <div class="container">
    <div class="sg-section-head">
      <h2 class="sg-section-title">Typography</h2>
      <span class="sg-section-num">02</span>
    </div>
    <p class="sg-section-desc">Two typefaces carry the editorial voice: <strong>Newsreader</strong> (serif, loaded from Google Fonts) for display and headings; <strong>Inter</strong> (sans-serif) for body copy and UI elements.</p>

    <div class="sg-type-stack">
      <div class="sg-type-row">
        <div class="sg-type-meta">
          <span class="sg-type-label">Display</span>
          <span class="sg-type-spec">Newsreader 400<br>clamp(48–80px)<br>-0.03em tracking</span>
        </div>
        <div class="sg-type-sample">
          <p class="sg-type-display">The <em>Edit</em> 03</p>
        </div>
      </div>
      <div class="sg-type-row">
        <div class="sg-type-meta">
          <span class="sg-type-label">Heading 1</span>
          <span class="sg-type-spec">Newsreader 400<br>clamp(34–54px)<br>-0.025em tracking</span>
        </div>
        <div class="sg-type-sample">
          <h1 class="sg-type-h1">Spring <em>Edition</em></h1>
        </div>
      </div>
      <div class="sg-type-row">
        <div class="sg-type-meta">
          <span class="sg-type-label">Heading 2</span>
          <span class="sg-type-spec">Newsreader 400<br>clamp(26–38px)<br>-0.02em tracking</span>
        </div>
        <div class="sg-type-sample">
          <h2 class="sg-type-h2">Editor's Picks</h2>
        </div>
      </div>
      <div class="sg-type-row">
        <div class="sg-type-meta">
          <span class="sg-type-label">Heading 3</span>
          <span class="sg-type-spec">Newsreader 500<br>clamp(20–28px)<br>-0.015em tracking</span>
        </div>
        <div class="sg-type-sample">
          <h3 class="sg-type-h3">Best Headphones of 2026</h3>
        </div>
      </div>
      <div class="sg-type-row">
        <div class="sg-type-meta">
          <span class="sg-type-label">Body</span>
          <span class="sg-type-spec">Inter 400<br>16px / 1.75<br>color: --muted</span>
        </div>
        <div class="sg-type-sample">
          <p class="sg-type-body">We test everything we sell. Our editors live with each product for a minimum of two weeks before it earns a place in the catalogue. The result: fewer things, chosen with far more care.</p>
        </div>
      </div>
      <div class="sg-type-row">
        <div class="sg-type-meta">
          <span class="sg-type-label">Small / Caption</span>
          <span class="sg-type-spec">Inter 400<br>13.5px / 1.65<br>color: --muted</span>
        </div>
        <div class="sg-type-sample">
          <p class="sg-type-small">Reviewed by the Curio editorial team · Updated April 2026</p>
        </div>
      </div>
      <div class="sg-type-row">
        <div class="sg-type-meta">
          <span class="sg-type-label">Label / Eyebrow</span>
          <span class="sg-type-spec">Inter 600<br>11.5–12px<br>0.12–0.15em tracking<br>UPPERCASE · --clay</span>
        </div>
        <div class="sg-type-sample">
          <span class="sg-type-label-sample">Issue 03 · Spring 2026</span>
        </div>
      </div>
      <div class="sg-type-row">
        <div class="sg-type-meta">
          <span class="sg-type-label">Monospace</span>
          <span class="sg-type-spec">SFMono / Consolas<br>13–13.5px / 1.6<br>color: --dusty-blue</span>
        </div>
        <div class="sg-type-sample">
          <code class="sg-type-mono">SHOPIFY_STOREFRONT_PRIVATE_TOKEN=shpat_...</code>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 3. Buttons -->
<section class="sg-section" id="sg-buttons">
  <div class="container">
    <div class="sg-section-head">
      <h2 class="sg-section-title">Buttons</h2>
      <span class="sg-section-num">03</span>
    </div>
    <p class="sg-section-desc">Three button tiers: primary (dark fill, main CTA), ghost (outlined, secondary actions), and text links. All include focus rings and hover transitions.</p>

    <div class="sg-btn-group">
      <p class="sg-btn-label">Primary</p>
      <div class="sg-btn-grid">
        <a class="btn-primary" href="#">
          Back home
          <svg viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06l2.97-2.97H3.75a.75.75 0 0 1 0-1.5h7.44L8.22 4.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
        </a>
        <a class="btn-primary" href="#" style="background:#9A6B4F;border-color:#9A6B4F;">
          Add to cart
          <svg viewBox="0 0 16 16" fill="currentColor"><path d="M2 1.75A.75.75 0 0 1 2.75 1h1.5a.75.75 0 0 1 .736.603l.265 1.397H13.25a.75.75 0 0 1 .735.894l-.888 4.444a.75.75 0 0 1-.735.606H6l.228 1.5h6.522a.75.75 0 0 1 0 1.5H5.75a.75.75 0 0 1-.738-.626L3.86 3.5H2.75A.75.75 0 0 1 2 2.75V1.75z"/></svg>
        </a>
        <button class="btn-primary" disabled style="opacity:0.4;cursor:not-allowed;">Disabled state</button>
      </div>
    </div>

    <div class="sg-btn-group">
      <p class="sg-btn-label">Ghost / Outline</p>
      <div class="sg-btn-grid">
        <a class="btn-ghost" href="#">Shop all products</a>
        <a class="btn-ghost" href="#" style="border-color:#9A6B4F;color:#9A6B4F;">Clay variant</a>
        <button class="btn-ghost" disabled style="opacity:0.4;cursor:not-allowed;">Disabled</button>
      </div>
    </div>

    <div class="sg-btn-group">
      <p class="sg-btn-label">Filter Pills</p>
      <div class="sg-btn-grid">
        <button class="sg-pill active">All</button>
        <button class="sg-pill">Headphones</button>
        <button class="sg-pill">Cameras</button>
        <button class="sg-pill">Laptops</button>
        <button class="sg-pill">Accessories</button>
      </div>
    </div>
  </div>
</section>

<!-- 4. Forms -->
<section class="sg-section" id="sg-forms">
  <div class="container">
    <div class="sg-section-head">
      <h2 class="sg-section-title">Form Elements</h2>
      <span class="sg-section-num">04</span>
    </div>
    <p class="sg-section-desc">Form controls share a unified height (48px), border radius, focus ring, and transition. Inputs sit on <code class="sg-inline-code">--warm-white</code> to lift off the cream page background.</p>

    <div class="sg-form-grid">
      <div class="sg-field">
        <label class="sg-field-label" for="sg-name">Full name</label>
        <input class="sg-input" id="sg-name" type="text" placeholder="e.g. Jordan Ashford" />
        <span class="sg-field-hint">As it appears on your account.</span>
      </div>
      <div class="sg-field">
        <label class="sg-field-label" for="sg-email">Email <span>*</span></label>
        <input class="sg-input" id="sg-email" type="email" placeholder="you@example.com" />
      </div>
      <div class="sg-field">
        <label class="sg-field-label" for="sg-select">Category</label>
        <select class="sg-select" id="sg-select">
          <option value="">Select a category…</option>
          <option>Headphones</option>
          <option>Cameras</option>
          <option>Laptops</option>
          <option>Accessories</option>
        </select>
      </div>
      <div class="sg-field">
        <label class="sg-field-label" for="sg-error">Discount code</label>
        <input class="sg-input sg-input--error" id="sg-error" type="text" value="INVALID2026" />
        <span class="sg-field-error">This code is not valid or has expired.</span>
      </div>
      <div class="sg-field sg-form-full">
        <label class="sg-field-label" for="sg-msg">Message</label>
        <textarea class="sg-textarea" id="sg-msg" rows="4" placeholder="Tell us what's on your mind…"></textarea>
      </div>
    </div>
  </div>
</section>

<!-- 5. Components -->
<section class="sg-section" id="sg-components">
  <div class="container">
    <div class="sg-section-head">
      <h2 class="sg-section-title">Components</h2>
      <span class="sg-section-num">05</span>
    </div>
    <p class="sg-section-desc">Reusable primitives that appear across the editorial theme. Combine tokens to stay consistent.</p>

    <div class="sg-component-grid">

      <div class="sg-demo-block">
        <span class="sg-demo-label">Eyebrow label</span>
        <span class="sg-eyebrow-demo"><span class="sg-eyebrow-demo-dot"></span>Issue 03 · Spring 2026</span>
      </div>

      <div class="sg-demo-block">
        <span class="sg-demo-label">Status badges</span>
        <div class="sg-badges">
          <span class="sg-badge sg-badge--green">In stock</span>
          <span class="sg-badge sg-badge--red">Sold out</span>
          <span class="sg-badge sg-badge--clay">New</span>
          <span class="sg-badge sg-badge--ink">Best seller</span>
          <span class="sg-badge sg-badge--sand">Coming soon</span>
        </div>
      </div>

      <div class="sg-demo-block--dark sg-demo-block">
        <span class="sg-demo-label">On dark surface</span>
        <p class="sg-dark-demo-hl">
          Tech, <em>curated.</em>
        </p>
        <p class="sg-dark-demo-sub">Stories, sold separately.</p>
      </div>

      <div class="sg-demo-block--cream sg-demo-block">
        <span class="sg-demo-label">Dividers</span>
        <div class="sg-divider-demos">
          <div>
            <p class="sg-divider-demo-label">--sand (light)</p>
            <div class="sg-divider sg-divider--sand"></div>
          </div>
          <div>
            <p class="sg-divider-demo-label">--sand-deep (medium)</p>
            <div class="sg-divider sg-divider--sand-deep"></div>
          </div>
          <div>
            <p class="sg-divider-demo-label">--ink / 8% (strong)</p>
            <div class="sg-divider sg-divider--ink"></div>
          </div>
        </div>
      </div>

    </div>

    <!-- Code block demo -->
    <div class="sg-subsection">
      <div class="sg-sub-title">Code / Inline tokens</div>
      <div class="sg-code">
        <pre><span class="tok-comment">/* Design tokens in use */</span>
<span class="tok-kw">:root</span> &#123;
  <span class="tok-prop">--ink</span>: <span class="tok-val">#111111</span>;         <span class="tok-comment">/* primary text */</span>
  <span class="tok-prop">--cream</span>: <span class="tok-val">#F7F2EA</span>;       <span class="tok-comment">/* page background */</span>
  <span class="tok-prop">--clay</span>: <span class="tok-val">#9A6B4F</span>;        <span class="tok-comment">/* accent / CTA */</span>
  <span class="tok-prop">--font-serif</span>: <span class="tok-val">'Newsreader'</span>, Georgia, serif;
  <span class="tok-prop">--t-base</span>: <span class="tok-val">320ms</span>;
  <span class="tok-prop">--ease</span>: <span class="tok-val">cubic-bezier(0.4, 0, 0.2, 1)</span>;
&#125;</pre>
      </div>
    </div>
  </div>
</section>

<!-- 6. Motion -->
<section class="sg-section" id="sg-motion">
  <div class="container">
    <div class="sg-section-head">
      <h2 class="sg-section-title">Motion</h2>
      <span class="sg-section-num">06</span>
    </div>
    <p class="sg-section-desc">Three timing tokens handle all transitions. Hover the cards to see each in action.</p>

    <div class="sg-motion-grid">
      <div class="sg-motion-card">
        <p class="sg-motion-name">Fast</p>
        <p class="sg-motion-spec">var(--t-fast)</p>
        <p class="sg-motion-spec">200ms · ease</p>
        <p class="sg-motion-hint">Hover tints, border-color, opacity. Instant-feeling feedback.</p>
      </div>
      <div class="sg-motion-card" style="transition-duration:320ms;">
        <p class="sg-motion-name">Base</p>
        <p class="sg-motion-spec">var(--t-base)</p>
        <p class="sg-motion-spec">320ms · ease</p>
        <p class="sg-motion-hint">Panel open/close, accordion expand, drawer slide.</p>
      </div>
      <div class="sg-motion-card" style="transition-duration:550ms;">
        <p class="sg-motion-name">Slow</p>
        <p class="sg-motion-spec">var(--t-slow)</p>
        <p class="sg-motion-spec">550ms · ease-out</p>
        <p class="sg-motion-hint">Modal entrance, hero cross-fade, scroll-reveal stagger.</p>
      </div>
    </div>

    <p class="sg-footer-note">
      All motion respects <code class="sg-inline-code">prefers-reduced-motion</code> — transitions are disabled globally when the OS preference is set.
    </p>
  </div>
</section>
