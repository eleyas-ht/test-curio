---
// LicensesBody.astro — Open source licenses & attributions.
---

<!-- Hero -->
<section class="lic-hero">
  <div class="container">
    <span class="lic-eyebrow"><span class="lic-eyebrow-dot"></span>Legal</span>
    <div class="lic-hero-grid">
      <div>
        <h1 class="lic-title">Open source <em>credits.</em></h1>
        <p class="lic-lead">Curio is built on a foundation of exceptional open source software. This page lists every library we depend on, with its license type and a link to the original source.</p>
        <p class="lic-lead" style="margin-top:-8px;">We are grateful to the maintainers of these projects.</p>
      </div>
      <div class="lic-hero-stat-col">
        <div class="lic-stat-row">
          <span class="lic-stat-key">Template</span>
          <span class="lic-stat-val">Omnix Editorial</span>
        </div>
        <div class="lic-stat-row">
          <span class="lic-stat-key">Version</span>
          <span class="lic-stat-val">1.3.0</span>
        </div>
        <div class="lic-stat-row">
          <span class="lic-stat-key">Dependencies</span>
          <span class="lic-stat-val">18 packages</span>
        </div>
        <div class="lic-stat-row">
          <span class="lic-stat-key">All licenses</span>
          <span class="lic-stat-badge">
            <svg viewBox="0 0 12 12" fill="currentColor" style="width:10px;height:10px;"><path fill-rule="evenodd" d="M10.03 2.47a.75.75 0 0 1 0 1.06L4.5 9.06 1.97 6.53a.75.75 0 0 1 1.06-1.06L4.5 6.94l4.47-4.47a.75.75 0 0 1 1.06 0z" clip-rule="evenodd"/></svg>
            OSI Approved
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Body -->
<div class="lic-body">
  <div class="container">

    <!-- Template own license -->
    <div class="lic-template">
      <div class="lic-template-tag">
        <svg viewBox="0 0 14 14" fill="currentColor" style="width:12px;height:12px;"><path d="M7 0a1 1 0 0 1 .894.553l1.828 3.703 4.09.595a1 1 0 0 1 .555 1.705L11.274 9.44l.7 4.073a1 1 0 0 1-1.45 1.054L7 12.576l-3.524 1.852a1 1 0 0 1-1.45-1.054l.7-4.073L.634 6.556a1 1 0 0 1 .555-1.705l4.09-.595L7.106.553A1 1 0 0 1 7 0z"/></svg>
        This template
      </div>
      <h2 class="lic-template-title">Omnix Editorial Style — Astro</h2>
      <p class="lic-template-body">
        This theme is a commercial template distributed under the <strong style="color:rgba(255,255,255,0.75);">Omnix Single-Use License</strong>. You may use it to build one end-product for yourself or one client. You may not redistribute or resell the template source. See the full license at <a href="https://omnixthemes.com/license">omnixthemes.com/license</a>.
      </p>
    </div>

    <!-- Core framework -->
    <div class="lic-section-head">
      <h2 class="lic-section-title">Framework &amp; Runtime</h2>
      <span class="lic-section-count">5 packages</span>
    </div>

    <div class="lic-list">
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">astro <span class="lic-pkg-version">^6.0.0</span></p>
            <p class="lic-pkg-desc">The web framework that powers SSR pages, routing, and component compilation.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/withastro/astro" target="_blank" rel="noopener">
            GitHub
            <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg>
          </a>
        </div>
      </div>
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">@astrojs/node <span class="lic-pkg-version">^10.0.0</span></p>
            <p class="lic-pkg-desc">Node.js server adapter for Astro SSR — powers the standalone production server.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/withastro/adapters" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">@astrojs/react <span class="lic-pkg-version">^4.0.0</span></p>
            <p class="lic-pkg-desc">Official React integration for Astro — enables interactive island components.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/withastro/astro" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">react &amp; react-dom <span class="lic-pkg-version">^19.0.0</span></p>
            <p class="lic-pkg-desc">UI runtime for interactive islands (cart drawer, search, gallery, compare bar).</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/facebook/react" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">@astrojs/tailwind + tailwindcss <span class="lic-pkg-version">v4</span></p>
            <p class="lic-pkg-desc">Utility-first CSS framework via the Vite plugin — used for React islands and utility overrides.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/tailwindlabs/tailwindcss" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
    </div>

    <!-- State & data -->
    <div class="lic-section-head" style="margin-top:52px;">
      <h2 class="lic-section-title">State Management &amp; Data</h2>
      <span class="lic-section-count">4 packages</span>
    </div>

    <div class="lic-list">
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">nanostores <span class="lic-pkg-version">^0.11.0</span></p>
            <p class="lic-pkg-desc">Tiny framework-agnostic state manager for the cart, wishlist, and compare stores.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/nanostores/nanostores" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">@nanostores/react <span class="lic-pkg-version">^0.8.0</span></p>
            <p class="lic-pkg-desc">React bindings for nanostores — connects islands to the shared cart/wishlist stores.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/nanostores/react" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">graphql-tag <span class="lic-pkg-version">^2.12.0</span></p>
            <p class="lic-pkg-desc">Template literal tag for parsing GraphQL operations sent to the Shopify Storefront API.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/apollographql/graphql-tag" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">zod <span class="lic-pkg-version">^3.23.0</span></p>
            <p class="lic-pkg-desc">TypeScript-first schema validation used in API routes and environment variable checks.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/colinhacks/zod" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
    </div>

    <!-- Typography & fonts -->
    <div class="lic-section-head" style="margin-top:52px;">
      <h2 class="lic-section-title">Fonts &amp; Assets</h2>
      <span class="lic-section-count">2 typefaces</span>
    </div>

    <div class="lic-list">
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">Newsreader</p>
            <p class="lic-pkg-desc">Google Fonts — display serif typeface used for headings, display text, and editorial headlines.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--apache">OFL 1.1</span>
          <a class="lic-item-link" href="https://fonts.google.com/specimen/Newsreader" target="_blank" rel="noopener">Google Fonts <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">Inter</p>
            <p class="lic-pkg-desc">Google Fonts — humanist sans-serif used for all UI text, body copy, and form elements.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--apache">OFL 1.1</span>
          <a class="lic-item-link" href="https://fonts.google.com/specimen/Inter" target="_blank" rel="noopener">Google Fonts <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
    </div>

    <!-- Dev tools -->
    <div class="lic-section-head" style="margin-top:52px;">
      <h2 class="lic-section-title">Dev &amp; Build Tools</h2>
      <span class="lic-section-count">7 packages</span>
    </div>

    <div class="lic-list">
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">vite <span class="lic-pkg-version">^6.0.0</span></p>
            <p class="lic-pkg-desc">Build tool and dev server underlying Astro — handles HMR, bundling, and asset pipeline.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/vitejs/vite" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">typescript <span class="lic-pkg-version">^5.7.0</span></p>
            <p class="lic-pkg-desc">Strict type-checking across all Astro pages, API routes, services, and components.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--apache">Apache 2.0</span>
          <a class="lic-item-link" href="https://github.com/microsoft/TypeScript" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
      <div class="lic-item">
        <div class="lic-item-left">
          <div>
            <p class="lic-pkg-name">@types/react &amp; @types/react-dom</p>
            <p class="lic-pkg-desc">TypeScript type definitions for React 19 — enables typed props and event handlers in islands.</p>
          </div>
        </div>
        <div class="lic-item-right">
          <span class="lic-badge lic-badge--mit">MIT</span>
          <a class="lic-item-link" href="https://github.com/DefinitelyTyped/DefinitelyTyped" target="_blank" rel="noopener">GitHub <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5v4"/></svg></a>
        </div>
      </div>
    </div>

    <!-- Full MIT license text (accordion) -->
    <div class="lic-full-acc" id="lic-mit-acc">
      <div class="lic-acc-item" id="lic-mit">
        <button class="lic-acc-trigger" aria-expanded="false" aria-controls="lic-mit-body">
          View MIT License text (applies to most packages above)
          <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
        </button>
        <div class="lic-acc-body" id="lic-mit-body" role="region">
          <div class="lic-acc-inner">
            <pre class="lic-license-text">MIT License

Copyright (c) [year] [package author]

Permission is hereby granted, free of charge, to any person obtaining a copy
of this software and associated documentation files (the "Software"), to deal
in the Software without restriction, including without limitation the rights
to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
copies of the Software, and to permit persons to whom the Software is
furnished to do so, subject to the following conditions:

The above copyright notice and this permission notice shall be included in all
copies or substantial portions of the Software.

THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
SOFTWARE.</pre>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.lic-acc-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.lic-acc-item');
      const isOpen = item?.classList.contains('open');
      item?.classList.toggle('open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
