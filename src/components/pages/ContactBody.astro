---
// 1:1 verbatim body from contact-editorial.html — all copy/data driven by ~/config/contact
import { CONTACT } from '~/config/contact';

// Build the repeating marquee line from config items
const marqueeLine = CONTACT.marquee.map((t) => `${t} <i>✦</i>`).join(' ') + ' ';
---

  <!-- ============================================================
     CONTACT
============================================================ -->
  <main class="ct">
    <!-- ===== HERO — oversized editorial statement ===== -->
    <section class="ct-hero">
      <div class="container">
        <nav class="cart-breadcrumb ct-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a><span class="cart-bc-sep">/</span>
          <span aria-current="page">Contact</span>
        </nav>
        <div class="ct-hero-top">
          <span class="label">{CONTACT.hero.label}</span>
          <span class="ct-hero-status"><span class="ct-dot"></span>{CONTACT.hero.statusText}</span>
        </div>
        <h1 class="ct-hero-title" set:html={CONTACT.hero.title} />
        <p class="ct-hero-lead">{CONTACT.hero.lead}</p>
      </div>
    </section>

    <!-- ===== MARQUEE ===== -->
    <div class="ct-marquee" aria-hidden="true">
      <div class="ct-marquee-track">
        <span set:html={marqueeLine} />
        <span set:html={marqueeLine} />
      </div>
    </div>

    <!-- ===== CONVERSATIONAL FORM (dark) ===== -->
    <section class="ct-talk">
      <div class="container ct-talk-inner">
        <div class="ct-talk-head">
          <span class="label label-on-dark">{CONTACT.form.label}</span>
          <span class="ct-talk-no">{CONTACT.form.sectionNumber}</span>
        </div>
        <form class="ct-fib" id="ct-form" novalidate>
          <p class="ct-fib-text">
            {CONTACT.form.greeting}
            <span class="ct-fib-field">
              <input type="text" id="ct-name" name="name" placeholder="your name" aria-label="Your name" autocomplete="name">
            </span>
            and I'd like to talk about
            <span class="ct-fib-field ct-fib-select">
              <select id="ct-topic" name="topic" aria-label="Topic">
                {CONTACT.form.topics.map((topic) => (
                  <option>{topic}</option>
                ))}
              </select>
            </span>.
            You can reach me at
            <span class="ct-fib-field">
              <input type="email" id="ct-email" name="email" placeholder="you@email.com" aria-label="Your email" autocomplete="email">
            </span>.
            Here's a little more —
            <span class="ct-fib-field ct-fib-block">
              <textarea id="ct-message" name="message" rows="2" placeholder="tell us what's on your mind…" aria-label="Your message"></textarea>
            </span>
          </p>

          <div class="ct-fib-foot">
            <button type="submit" class="ct-send">
              {CONTACT.form.submitLabel}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <span class="ct-fib-hint" id="ct-fib-hint">{CONTACT.form.hintText}</span>
          </div>

          <p class="ct-form-note" id="ct-form-note" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m5 13 4 4 10-10" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {CONTACT.form.successMessage}
          </p>
        </form>
      </div>
    </section>

    <!-- ===== DIRECTORY + INFO ===== -->
    <section class="ct-dir">
      <div class="container ct-dir-grid">
        <div class="ct-dir-list">
          <div class="ct-dir-head">
            <span class="label">{CONTACT.directory.label}</span>
            <h2 class="ct-h2" set:html={CONTACT.directory.heading} />
          </div>

          {CONTACT.directory.channels.map((ch) => (
            <a class="ct-chan" href={ch.href}>
              <span class="ct-chan-no">{ch.no}</span>
              <span class="ct-chan-body">
                <span class="ct-chan-label">{ch.label}</span>
                <span class="ct-chan-val">{ch.value}</span>
              </span>
              <svg class="ct-chan-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M7 17 17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          ))}
        </div>

        <aside class="ct-side">
          <div class="ct-side-card">
            <h3 class="ct-side-title">{CONTACT.directory.hours.title}</h3>
            <ul class="ct-hours">
              {CONTACT.directory.hours.schedule.map((slot) => (
                <li>
                  <span>{slot.days}</span>
                  <span class={slot.closed ? 'ct-closed' : undefined}>{slot.hours}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="ct-side-card ct-side-card-dark">
            <h3 class="ct-side-title">{CONTACT.directory.socialCard.title}</h3>
            <p class="ct-side-sub">{CONTACT.directory.socialCard.subtitle}</p>
            <div class="ct-social">
              {CONTACT.directory.socialCard.links.map((link) => (
                <a href={link.href} aria-label={link.label}>
                  {link.icon === 'instagram' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
                  )}
                  {link.icon === 'x' && (
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 3h3l-6.5 7.4L21.7 21h-6l-4.7-6-5.4 6H2.6l7-7.9L2.3 3h6.2l4.2 5.6L17.5 3zm-1 16h1.6L7.6 4.7H5.9L16.5 19z"/></svg>
                  )}
                  {link.icon === 'youtube' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="6" width="18" height="12" rx="3"/><path d="m11 9.5 4 2.5-4 2.5z" fill="currentColor" stroke="none"/></svg>
                  )}
                  {link.icon === 'linkedin' && (
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.08 1.4-2.08 2.85V21h-4z"/></svg>
                  )}
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- ===== MAP ===== -->
    <section class="ct-map" id="ct-map">
      <div class="container">
        <div class="ct-map-wrap">
          <iframe
            src={CONTACT.map.iframeSrc}
            title={CONTACT.map.iframeTitle}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <div class="ct-map-card">
            <span class="label">{CONTACT.map.label}</span>
            <h3 class="ct-map-title">{CONTACT.map.title}</h3>
            <p>{CONTACT.map.description}</p>
            <a href={CONTACT.map.directionsHref} class="ab-text-link">{CONTACT.map.directionsLabel}</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <section class="section-newsletter">
    <div class="container newsletter-inner">
      <span class="label label-center newsletter-eyebrow">{CONTACT.newsletter.eyebrow}</span>
      <h2 class="newsletter-title" set:html={CONTACT.newsletter.title} />
      <p class="newsletter-body">{CONTACT.newsletter.body}</p>
      <form class="newsletter-form" id="nl-form">
        <input class="newsletter-input" type="email" name="email" placeholder={CONTACT.newsletter.placeholder} required>
        <button type="submit" class="newsletter-submit">{CONTACT.newsletter.submitLabel}</button>
      </form>
      <p class="newsletter-fine" set:html={CONTACT.newsletter.finePrint} />
    </div>
  </section>

  <!-- Account dropdown -->
  <div class="acct-menu" id="acct-menu" hidden>
    <div class="acct-head">
      <span class="acct-hello">Welcome to <strong>The Edit</strong></span>
      <span class="acct-sub">Sign in for faster checkout &amp; order tracking</span>
    </div>
    <div class="acct-actions">
      <button class="acct-signin">Sign in</button>
      <button class="acct-create">Create account</button>
    </div>
    <nav class="acct-links">
      <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2h9l5 5v15H6z" stroke-linejoin="round" />
          <path d="M9 12h6M9 16h6" stroke-linecap="round" />
        </svg>My orders</a>
      <a href="#" id="acct-wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path
            d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1.1-1.1a5.5 5.5 0 1 0-7.8 7.8L12 21.2l8.8-8.8a5.5 5.5 0 0 0 0-7.8z"
            stroke-linejoin="round" />
        </svg>Wishlist</a>
      <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="10" r="3" />
          <path d="M5 20c0-3.5 3-5 7-5s7 1.5 7 5" stroke-linecap="round" />
        </svg>Account settings</a>
      <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="9" />
          <path d="M9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.7.4-1 .8-1 1.7M12 17h.01" stroke-linecap="round" />
        </svg>Help &amp; support</a>
    </nav>
  </div>
