---
import {
  ABOUT_HERO,
  ABOUT_MANIFESTO,
  ABOUT_STORY,
  ABOUT_VALUES,
  ABOUT_JOURNEY,
  ABOUT_VIDEO,
  ABOUT_NOTE,
  ABOUT_TEAM,
  ABOUT_FAQS,
} from '~/config/about';
import { SITE } from '~/config/site';
import Newsletter from '~/components/home/sections/Newsletter.astro';
---

  <!-- ============================================================
     ABOUT — HERO
  ============================================================ -->
  <main class="ab">

    <!-- ============ HERO ============ -->
    <section class="ab-hero">
      <span class="ab-hero-watermark" aria-hidden="true">{ABOUT_HERO.watermark}</span>
      <div class="container">
        <nav class="cart-breadcrumb ab-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a><span class="cart-bc-sep">/</span>
          <span aria-current="page">About</span>
        </nav>
        <div class="ab-hero-head">
          <span class="label label-center ab-center">{ABOUT_HERO.eyebrow}</span>
          <h1 class="ab-hero-title" set:html={ABOUT_HERO.title} />
          <p class="ab-hero-lead">{ABOUT_HERO.lead}</p>
          <div class="ab-hero-actions">
            <a href={ABOUT_HERO.cta.href} class="btn-primary">
              {ABOUT_HERO.cta.label}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <a href="#ab-story" class="ab-text-link">{ABOUT_HERO.storyLink}</a>
          </div>
        </div>
      </div>

      <!-- Showcase with badge -->
      <div class="container">
        <div class="ab-hero-showcase-media" id="ab-hero-slider">
          <div class="ab-hero-slides">
            {ABOUT_HERO.slides.map((slide, i) => (
              <div class:list={['ab-hero-slide', { active: i === 0 }]}>
                <img src={slide.src} alt={slide.alt} />
              </div>
            ))}
          </div>

          <div class="ab-hero-caption">
            <span class="ab-hero-tagline">{ABOUT_HERO.tagline}</span>
            <p class="ab-hero-tagsub">{ABOUT_HERO.tagsub}</p>
          </div>

          <span class="ab-hero-chip">
            <span class="ab-hero-chip-num">{ABOUT_HERO.chip.num}</span>
            <span class="ab-hero-chip-label" set:html={ABOUT_HERO.chip.label} />
          </span>
        </div>

        <!-- Stats row -->
        <div class="ab-hero-stats">
          {ABOUT_HERO.stats.map((stat) => (
            <div class="ab-stat">
              <span class="ab-stat-num">
                {stat.num}{stat.sup && <sup>{stat.sup}</sup>}
              </span>
              <span class="ab-stat-label">
                {stat.label.split('\n').map((line, i, arr) => (
                  <>
                    {line}
                    {i < arr.length - 1 && <br />}
                  </>
                ))}
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ MANIFESTO ============ -->
    <section class="ab-manifesto">
      <div class="container">
        <span class="label label-center ab-center">{ABOUT_MANIFESTO.eyebrow}</span>
        <p class="ab-manifesto-text" set:html={ABOUT_MANIFESTO.text} />
      </div>
    </section>

    <!-- ============ STORY ============ -->
    <section class="ab-story" id="ab-story">
      <div class="container ab-story-grid">
        <div class="ab-story-media">
          <div class="ab-story-imgwrap">
            <img src={ABOUT_STORY.img1.src} alt={ABOUT_STORY.img1.alt} class="ab-story-img" />
            <img src={ABOUT_STORY.img2.src} alt={ABOUT_STORY.img2.alt} class="ab-story-img2" />
            <span class="ab-story-est">
              <span class="ab-story-est-eb">Est.</span>
              <span class="ab-story-est-yr">{ABOUT_STORY.estYear}</span>
            </span>
          </div>
        </div>
        <div class="ab-story-copy">
          <span class="label">How it started</span>
          <h2 class="ab-h2" set:html={ABOUT_STORY.h2} />
          <p class="ab-story-lead">{ABOUT_STORY.lead}</p>
          {ABOUT_STORY.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <!-- ============ OUR CORE VALUES ============ -->
    <section class="ab-values">
      <div class="container ab-values-layout">
        <div class="ab-values-intro">
          <span class="label">Our core values</span>
          <h2 class="ab-h2">Principles we don't <em>negotiate</em> on.</h2>
          <p class="ab-values-lead">Four ideas shape every decision we make — from which products make
            the edit to how we reply to your emails. They're not poster slogans; they're the filter
            everything has to pass through.</p>
          <a href="#ab-story" class="ab-text-link">See how it started</a>
        </div>

        <div class="ab-values-list">
          {ABOUT_VALUES.map((val) => (
            <article class="ab-value ab-reveal">
              <span class="ab-value-num">{val.num}</span>
              <span class="ab-value-ico">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={val.iconHtml} />
              </span>
              <div class="ab-value-body">
                <h3 class="ab-value-title">{val.title}</h3>
                <p>{val.body}</p>
                <span class="ab-value-tag">{val.tag}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ THE JOURNEY — interactive year tabs ============ -->
    <section class="ab-timeline">
      <div class="container">
        <div class="ab-values-head ab-jr2-head">
          <span class="label">The journey</span>
          <h2 class="ab-h2">Nine years, one <em>filter</em>.</h2>
        </div>

        <!-- year nav -->
        <div class="ab-jr2-nav" role="tablist">
          {ABOUT_JOURNEY.map((milestone, i) => (
            <button
              class:list={['ab-jr2-tab', { active: i === 0 }]}
              data-i={String(i)}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              <span class="ab-jr2-tab-year">{milestone.year}</span>
              <span class="ab-jr2-tab-label">{milestone.label}</span>
            </button>
          ))}
        </div>

        <!-- swapping panels -->
        <div class="ab-jr2-stage">
          {ABOUT_JOURNEY.map((milestone, i) => (
            <article class:list={['ab-jr2-panel', { active: i === 0 }]} data-i={String(i)}>
              <div class="ab-jr2-media">
                <img src={milestone.img.src} alt={milestone.img.alt} />
                <span class="ab-jr2-stamp">{milestone.stamp}</span>
              </div>
              <div class="ab-jr2-body">
                <span class="ab-jr2-chapter">{milestone.chapter}</span>
                <h3 class="ab-jr2-title">{milestone.title}</h3>
                <p class="ab-jr2-text">{milestone.text}</p>
                <span class="ab-jr2-meta">{milestone.meta}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ FULL-WIDTH VIDEO ============ -->
    <section class="ab-video">
      <video class="ab-video-el" autoplay muted loop playsinline poster={ABOUT_VIDEO.poster}>
        <source src={ABOUT_VIDEO.src} type="video/mp4" />
      </video>
      <div class="ab-video-overlay"></div>
      <div class="container ab-video-inner">
        <span class="label label-center ab-center ab-video-label">{ABOUT_VIDEO.eyebrow}</span>
        <h2 class="ab-video-title" set:html={ABOUT_VIDEO.title} />
        <p class="ab-video-sub">{ABOUT_VIDEO.sub}</p>
      </div>
    </section>

    <!-- ============ FOUNDER'S NOTE ============ -->
    <section class="ab-note">
      <div class="container ab-note-inner">
        <span class="label label-center ab-center">{ABOUT_NOTE.eyebrow}</span>
        <p class="ab-note-text" set:html={ABOUT_NOTE.quote} />
        <p class="ab-note-body">{ABOUT_NOTE.body}</p>
        <div class="ab-note-sign">
          <img class="ab-note-avatar" src={ABOUT_NOTE.founder.avatar} alt={ABOUT_NOTE.founder.name} />
          <div class="ab-note-by">
            <span class="ab-note-name">{ABOUT_NOTE.founder.name}</span>
            <span class="ab-note-role">{ABOUT_NOTE.founder.role}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ TEAM ============ -->
    <section class="ab-team" id="ab-team">
      <div class="container">
        <div class="ab-values-head">
          <span class="label">The humans behind it</span>
          <h2 class="ab-h2">Small team, <em>strong opinions.</em></h2>
        </div>
        <div class="ab-team-grid">
          {ABOUT_TEAM.map((member) => (
            <article class="ab-member ab-reveal" data-member-href={`/team/${member.slug}`}>
              <div class="ab-member-img">
                <img src={member.image} alt={member.name} />
                <span class="ab-member-tag">{member.tag}</span>
                <div class="ab-member-overlay">
                  <p class="ab-member-bio">{member.bio}</p>
                  <div class="ab-member-social">
                    {member.social.twitter && (
                      <a href={member.social.twitter} aria-label={`${member.name} on X`}>
                        <svg viewBox="0 0 24 24" fill="currentColor">
                          <path d="M17.5 3h3l-6.5 7.4L21.7 21h-6l-4.7-6-5.4 6H2.6l7-7.9L2.3 3h6.2l4.2 5.6L17.5 3zm-1 16h1.6L7.6 4.7H5.9L16.5 19z" />
                        </svg>
                      </a>
                    )}
                    {member.social.linkedin && (
                      <a href={member.social.linkedin} aria-label={`${member.name} on LinkedIn`}>
                        <svg viewBox="0 0 24 24" fill="currentColor">
                          <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.08 1.4-2.08 2.85V21h-4z" />
                        </svg>
                      </a>
                    )}
                    {member.social.email && (
                      <a href={`mailto:${member.social.email}`} aria-label={`Email ${member.name}`}>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                          <rect x="3" y="5" width="18" height="14" rx="2" />
                          <path d="m3 7 9 6 9-6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              </div>
              <h3 class="ab-member-name">
                <a href={`/team/${member.slug}`}>{member.name}</a>
              </h3>
              <p class="ab-member-role">{member.role}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section class="section-faq">
      <div class="container faq-inner">
        <div class="faq-left">
          <span class="label faq-eyebrow">Questions, answered</span>
          <h2 class="faq-title">The honest <em>fine print</em>.</h2>
          <p class="faq-body">No call-centre script. These are the questions people ask us most about who
            we are and how we work — answered the way we'd answer a friend.</p>
          <a href="/contact" class="btn-link">Talk to a human
            <svg viewBox="0 0 16 16" fill="currentColor">
              <path fill-rule="evenodd"
                d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06l2.97-2.97H3.75a.75.75 0 0 1 0-1.5h7.44L8.22 4.03a.75.75 0 0 1 0-1.06Z"
                clip-rule="evenodd" />
            </svg>
          </a>
        </div>
        <div class="faq-list">
          {ABOUT_FAQS.map((faq) => (
            <div class:list={['faq-item', { open: faq.open }]}>
              <button class="faq-q">
                <span class="faq-q-num">{faq.num}</span>
                <span class="faq-q-text">{faq.q}</span>
                <span class="faq-q-icon">
                  <svg viewBox="0 0 24 24">
                    <path d="M12 5v14M5 12h14" />
                  </svg>
                </span>
              </button>
              <div class="faq-a">
                <div class="faq-a-inner">{faq.a}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <!-- ============================================================
     TRUST STRIP (matches home)
  ============================================================ -->
  <section class="trust">
    <div class="container">
      <div class="trust-grid">
        {SITE.valueProps.map((prop) => (
          <div class="trust-item">
            <div class="trust-icon">
              {prop.icon === 'truck' && (
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5">
                  <path d="M3 7h13l4 4v6h-3a2 2 0 1 1-4 0H8a2 2 0 1 1-4 0H3V7Z" />
                  <circle cx="8" cy="17" r="1.5" /><circle cx="16" cy="17" r="1.5" />
                </svg>
              )}
              {prop.icon === 'rotate' && (
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5">
                  <path d="M3 12a9 9 0 1 0 3-6.7" /><path d="M3 5v4h4" />
                </svg>
              )}
              {prop.icon === 'shield' && (
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5">
                  <path d="M12 3 4 6v6c0 4.5 3 8 8 9 5-1 8-4.5 8-9V6l-8-3Z" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
              )}
              {prop.icon === 'clock' && (
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5">
                  <circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" />
                </svg>
              )}
            </div>
            <div class="trust-text">
              <span class="trust-title">{prop.title}</span>
              <span class="trust-sub">{prop.body}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
     FINAL CTA — Newsletter (shared home component)
  ============================================================ -->
  <Newsletter />

  <!-- Account dropdown -->
  <div class="acct-menu" id="acct-menu" hidden>
    <div class="acct-head">
      <span class="acct-hello">Welcome to <strong>The Edit</strong></span>
      <span class="acct-sub">Sign in for faster checkout &amp; order tracking</span>
    </div>
    <div class="acct-actions">
      <button class="acct-signin">Sign in</button>
      <button class="acct-create">Create account</button>
    </div>
    <nav class="acct-links">
      <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2h9l5 5v15H6z" stroke-linejoin="round" />
          <path d="M9 12h6M9 16h6" stroke-linecap="round" />
        </svg>My orders</a>
      <a href="#" id="acct-wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1.1-1.1a5.5 5.5 0 1 0-7.8 7.8L12 21.2l8.8-8.8a5.5 5.5 0 0 0 0-7.8z"
            stroke-linejoin="round" />
        </svg>Wishlist</a>
      <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="10" r="3" />
          <path d="M5 20c0-3.5 3-5 7-5s7 1.5 7 5" stroke-linecap="round" />
        </svg>Account settings</a>
      <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="9" />
          <path d="M9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.7.4-1 .8-1 1.7M12 17h.01" stroke-linecap="round" />
        </svg>Help &amp; support</a>
    </nav>
  </div>
