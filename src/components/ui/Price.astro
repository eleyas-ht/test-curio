---
// ============================================================
//  Price — tabular money with optional sale strikethrough.
//  Editorial: Inter, tabular figures (no mono).
// ============================================================
import { formatMoney, isOnSale } from '~/lib/utils';
import type { Money } from '~/lib/shopify/types';
import { cn } from '~/lib/utils';

interface Props {
  price: Money;
  compareAt?: Money | null;
  /** Prefix with "From" for price ranges (min variant price). */
  from?: boolean;
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { price, compareAt = null, from = false, class: className, size = 'md' } = Astro.props;

const onSale = isOnSale(price, compareAt);
const sizeClass = { sm: 'text-sm', md: 'text-[0.95rem]', lg: 'text-xl' }[size];
---

<span class={cn('inline-flex items-baseline gap-2 font-sans tabular', sizeClass, className)}>
  {from && <span class="text-[0.7em] uppercase tracking-wider text-muted-light">From</span>}
  <span class={cn('font-semibold', onSale ? 'text-clay-deep' : 'text-ink')}>
    {formatMoney(price.amount, price.currencyCode)}
  </span>
  {
    onSale && compareAt && (
      <s class="font-normal text-muted-light decoration-1">
        {formatMoney(compareAt.amount, compareAt.currencyCode)}
      </s>
    )
  }
</span>
