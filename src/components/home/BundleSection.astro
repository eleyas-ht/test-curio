---
// ============================================================
//  BundleSection — Astro port of the former React island.
//
//  Renders the CURATED BUNDLE section server-side (slide 0) and
//  enhances it with a vanilla-TS <script> that reproduces every
//  interaction the React island had:
//    • Multi-slide carousel with the .switching fade transition
//    • Per-item toggle (include / exclude) with the opacity fade
//    • Per-item variant selector (Shopify mode)
//    • Live subtotal / savings recalculation + price flash
//    • Add-to-cart (sequential Shopify calls) + discount code merge
//    • Success flash after add-to-cart
//
//  Markup is generated by ~/components/home/bundle-render so the
//  server HTML and the client-updated HTML share one source.
// ============================================================
import type { BundleSlideData } from './bundle.types';
import { contentInner, type BundleState } from './bundle-render';

interface Props {
  slides: BundleSlideData[];
}

const { slides } = Astro.props;
const first = slides[0];

// Initial interaction state: slide 0, everything selected, variant 0.
const initialState: BundleState = {
  cur: 0,
  off: (first?.items ?? []).map(() => false),
  variants: (first?.items ?? []).map(() => 0),
  adding: false,
  addSuccess: false,
  switching: false,
};

// Embedded for the client script. Escape "<" so a "</script>" or stray
// "<" inside product data can't break out of the JSON <script> tag.
const serializedSlides = JSON.stringify(slides).replace(/</g, '\\u003c');
---

{
  first && (
    <section class="section-bundle">
      <div class="container bundle-inner">
        {/* Left panel: hero image */}
        <div class="bundle-image">
          <img src={first.heroImage} alt={first.label} />
        </div>

        {/* Right panel: server-rendered from the shared builder; the client
            script binds to this exact markup and updates it in place. */}
        <div class="bundle-content" set:html={contentInner(initialState, slides)} />
      </div>

      <script type="application/json" id="bundle-slides-data" is:inline set:html={serializedSlides} />
    </section>
  )
}

<script>
  import { addItem, openCart, applyDiscount, $cart } from '~/stores/cart';
  import {
    contentInner,
    itemHtml,
    totalInner,
    ctaInner,
    selectedIndices,
    allSelected,
    noneSelected,
    type BundleState,
  } from '~/components/home/bundle-render';
  import type { BundleSlideData } from '~/components/home/bundle.types';

  const dataEl = document.getElementById('bundle-slides-data');
  const root = document.querySelector<HTMLElement>('.section-bundle');

  if (dataEl && root) {
    const slides = JSON.parse(dataEl.textContent || '[]') as BundleSlideData[];
    const total = slides.length;
    const imageEl = root.querySelector<HTMLImageElement>('.bundle-image img');
    const contentEl = root.querySelector<HTMLElement>('.bundle-content');

    if (slides.length && contentEl) {
      const state: BundleState = {
        cur: 0,
        off: slides[0].items.map(() => false),
        variants: slides[0].items.map(() => 0),
        adding: false,
        addSuccess: false,
        switching: false,
      };

      const slide = () => slides[state.cur];

      // ── Targeted updates (preserve the CSS transitions) ──────────

      function updateTotals() {
        const el = contentEl!.querySelector('.bundle-total');
        if (el) el.innerHTML = totalInner(state, slide());
      }

      function updateCta() {
        const btn = contentEl!.querySelector<HTMLButtonElement>('.btn-primary');
        if (!btn) return;
        const none = noneSelected(state, slide());
        btn.disabled = none || state.adding;
        btn.style.opacity = none ? '0.45' : '';
        btn.style.pointerEvents = none ? 'none' : '';
        btn.innerHTML = ctaInner(state, slide());
      }

      function toggleItem(i: number) {
        state.off[i] = !state.off[i];
        // Toggle the class on the live node so the .off opacity fade animates.
        const itemEl = contentEl!.querySelector(`.bundle-item[data-idx="${i}"]`);
        itemEl?.classList.toggle('off', state.off[i]);
        updateTotals();
        updateCta();
      }

      function setVariant(i: number, vi: number) {
        state.variants[i] = vi;
        const itemEl = contentEl!.querySelector(`.bundle-item[data-idx="${i}"]`);
        if (itemEl) itemEl.outerHTML = itemHtml(state, slide(), i);
        updateTotals();
        updateCta();
      }

      // ── Slide navigation (full re-render behind the fade) ────────

      function goTo(n: number) {
        if (state.switching || total <= 1) return;
        state.switching = true;
        contentEl!.classList.add('switching');
        imageEl?.classList.add('switching');
        // Wait for the fade-out, swap content, then fade back in.
        setTimeout(() => {
          state.cur = ((n % total) + total) % total;
          state.off = slides[state.cur].items.map(() => false);
          state.variants = slides[state.cur].items.map(() => 0);
          state.addSuccess = false;
          contentEl!.innerHTML = contentInner(state, slides);
          if (imageEl) {
            imageEl.src = slides[state.cur].heroImage;
            imageEl.alt = slides[state.cur].label;
          }
          // Double RAF mirrors the reference: let new content paint first.
          requestAnimationFrame(() =>
            requestAnimationFrame(() => {
              state.switching = false;
              contentEl!.classList.remove('switching');
              imageEl?.classList.remove('switching');
            }),
          );
        }, 260);
      }

      // ── Add to cart ──────────────────────────────────────────────

      async function handleAddToCart() {
        const sel = selectedIndices(state, slide());
        if (sel.length === 0 || state.adding) return;
        const s = slide();

        if (!s.isShopifyMode) {
          // Custom mode: animate success without a real cart add.
          state.adding = true;
          updateCta();
          await new Promise<void>((r) => setTimeout(r, 550));
          state.adding = false;
          state.addSuccess = true;
          updateCta();
          setTimeout(() => {
            state.addSuccess = false;
            updateCta();
          }, 1800);
          return;
        }

        const toAdd = sel
          .map((i) => s.items[i].variants?.[state.variants[i] ?? 0]?.id)
          .filter((id): id is string => Boolean(id));
        if (toAdd.length === 0) return;

        state.adding = true;
        updateCta();
        try {
          // Stamp each line with the bundle discount % so the drawer can show
          // savings even before Shopify confirms the discount code applies.
          const bundleAttrs =
            allSelected(state, s) && s.discount > 0
              ? [{ key: '_bundleDiscount', value: String(s.discount) }]
              : undefined;

          // Add sequentially; keep the drawer closed until all are in.
          for (const id of toAdd) {
            await addItem(id, 1, { open: false, attributes: bundleAttrs });
          }

          // Merge the bundle code with any codes the shopper already has.
          if (allSelected(state, s) && s.discountCode) {
            const existing = ($cart.get()?.discountCodes ?? [])
              .map((d) => d.code)
              .filter(Boolean);
            const merged = [...new Set([...existing, s.discountCode])];
            await applyDiscount(merged);
          }

          openCart();
          state.addSuccess = true;
          updateCta();
          setTimeout(() => {
            state.addSuccess = false;
            updateCta();
          }, 1800);
        } finally {
          state.adding = false;
          updateCta();
        }
      }

      // ── Event delegation on the persistent content container ─────

      contentEl.addEventListener('click', (e) => {
        const t = e.target as HTMLElement;
        // Clicks inside the variant <select> must not toggle the item.
        if (t.closest('.bundle-item-variant-select')) return;
        if (t.closest('.bundle-nav-arrow')) {
          goTo(state.cur + 1);
          return;
        }
        if (t.closest('.btn-primary')) {
          void handleAddToCart();
          return;
        }
        const itemEl = t.closest<HTMLElement>('.bundle-item');
        if (itemEl && itemEl.dataset.idx != null) {
          toggleItem(Number(itemEl.dataset.idx));
        }
      });

      contentEl.addEventListener('change', (e) => {
        const selEl = (e.target as HTMLElement).closest<HTMLSelectElement>(
          '.bundle-item-variant-select',
        );
        if (!selEl) return;
        const itemEl = selEl.closest<HTMLElement>('.bundle-item');
        if (itemEl && itemEl.dataset.idx != null) {
          setVariant(Number(itemEl.dataset.idx), Number(selEl.value));
        }
      });
    }
  }
</script>
