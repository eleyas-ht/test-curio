---
// ============================================================
//  Promo Grid — three editorial promo cards with image overlays.
//  Static config (map images/links to real collections as needed).
// ============================================================
import { Image } from 'astro:assets';
import Icon from '~/components/ui/Icon.astro';
import { PROMOS } from '~/config/promos';
import { img } from '~/lib/assets';
---

<section class="wrap py-20 md:py-28">
  <div class="grid gap-6 md:grid-cols-3">
    {
      PROMOS.map((promo) => {
        const cover = img(promo.image);
        return (
          <a href={promo.href} class="group relative block overflow-hidden rounded-md">
            <div class="aspect-[3/4] bg-warm-white">
              {cover && (
                <Image
                  src={cover}
                  alt={promo.title}
                  widths={[400, 640]}
                  sizes="(min-width: 768px) 33vw, 100vw"
                  class="h-full w-full object-cover transition-transform duration-[700ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.05]"
                />
              )}
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-cocoa/80 via-cocoa/10 to-transparent" />
            <span class="absolute left-5 top-5 rounded-sm bg-warm-white/90 px-2.5 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-ink backdrop-blur-sm">
              {promo.badge}
            </span>
            <div class="absolute inset-x-0 bottom-0 p-6 text-cream">
              <p class="ed-label is-center justify-start text-clay before:bg-clay">{promo.category}</p>
              <h3 class="mt-2 font-serif text-2xl text-cream">{promo.title}</h3>
              <span class="mt-3 inline-flex items-center gap-2 text-sm text-cream/90 transition-fluid group-hover:gap-3">
                Shop {promo.category}
                <Icon name="arrowRight" size={15} />
              </span>
            </div>
          </a>
        );
      })
    }
  </div>
</section>
