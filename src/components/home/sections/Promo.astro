---
// 1:1 verbatim from home-editorial.html (paths/links fixed)
import { imgUrl } from '~/lib/assets';
---
  <section class="section-promo-grid">
    <div class="container">
      <div class="promo-grid">
        <div class="promo-card">
          <img class="promo-card-img" src={imgUrl("/images/close-up-camera-tripod-sandy-beach-camera-with-lens.jpg")}
            alt="Camera collection" loading="lazy">
          <div class="promo-overlay"></div>
          <span class="promo-badge">New Arrivals</span>
          <div class="promo-body">
            <span class="promo-cat">Photography</span>
            <h3 class="promo-title">Capture the moment — mirrorless & beyond</h3>
            <span class="promo-cta">Shop cameras
              <svg viewBox="0 0 16 16" fill="currentColor">
                <path fill-rule="evenodd"
                  d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06l2.97-2.97H3.75a.75.75 0 0 1 0-1.5h7.44L8.22 4.03a.75.75 0 0 1 0-1.06Z"
                  clip-rule="evenodd" />
              </svg>
            </span>
          </div>
        </div>
        <div class="promo-card">
          <img class="promo-card-img"
            src={imgUrl("/images/person-wearing-health-technology-like-smartwatch-monitoring-vital-signs-exercise.jpg")}
            alt="Smartwatch collection" loading="lazy">
          <div class="promo-overlay"></div>
          <span class="promo-badge">Best Seller</span>
          <div class="promo-body">
            <span class="promo-cat">Wearables</span>
            <h3 class="promo-title">Health meets style — smartwatches built for life</h3>
            <span class="promo-cta">Shop wearables
              <svg viewBox="0 0 16 16" fill="currentColor">
                <path fill-rule="evenodd"
                  d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06l2.97-2.97H3.75a.75.75 0 0 1 0-1.5h7.44L8.22 4.03a.75.75 0 0 1 0-1.06Z"
                  clip-rule="evenodd" />
              </svg>
            </span>
          </div>
        </div>
        <div class="promo-card">
          <img class="promo-card-img" src={imgUrl("/images/wireless-earbuds-charging-case-dark-surface.jpg")} alt="Audio collection"
            loading="lazy">
          <div class="promo-overlay"></div>
          <span class="promo-badge">Staff Pick</span>
          <div class="promo-body">
            <span class="promo-cat">Audio</span>
            <h3 class="promo-title">Wireless freedom — earbuds & headphones curated</h3>
            <span class="promo-cta">Shop audio
              <svg viewBox="0 0 16 16" fill="currentColor">
                <path fill-rule="evenodd"
                  d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06l2.97-2.97H3.75a.75.75 0 0 1 0-1.5h7.44L8.22 4.03a.75.75 0 0 1 0-1.06Z"
                  clip-rule="evenodd" />
              </svg>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

