---
// 1:1 verbatim from home-editorial.html (paths/links fixed)
import { imgUrl } from '~/lib/assets';
---
  <section class="section-departments">
    <div class="container">
      <div class="dept-spread">

        <!-- LEFT — editorial intro -->
        <div class="dept-intro">
          <div class="dept-intro-no">The Edit · No. 06</div>
          <h2>Browse by <em>department</em>.</h2>
          <p class="dept-intro-lead">Six carefully selected departments — each one curated by our editors with
            intent. No bloated catalogues, no filler products, just the gear worth your attention this season.</p>
          <a href="#" class="dept-intro-link">
            View all departments
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
        </div>

        <!-- RIGHT — TOC list -->
        <div class="dept-toc">

          <a href="#" class="dept-row">
            <span class="dept-num">01</span>
            <div class="dept-info">
              <span class="dept-row-name">Headphones</span>
              <span class="dept-row-desc">Studio-grade sound, lifestyle-grade design.</span>
            </div>
            <span class="dept-row-count">42 items</span>
            <div class="dept-row-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
                stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
            <div class="dept-row-img"><img src={imgUrl("/images/magnific_warm-neutral-surface-head_gJIgbmiSXO.png")} alt="Headphones"></div>
          </a>

          <a href="#" class="dept-row">
            <span class="dept-num">02</span>
            <div class="dept-info">
              <span class="dept-row-name">Speakers</span>
              <span class="dept-row-desc">Room-filling sound, room-defining presence.</span>
            </div>
            <span class="dept-row-count">28 items</span>
            <div class="dept-row-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
                stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
            <div class="dept-row-img"><img src={imgUrl("/images/mp51zp5u-speaker.jpg")} alt="Speakers"></div>
          </a>

          <a href="#" class="dept-row">
            <span class="dept-num">03</span>
            <div class="dept-info">
              <span class="dept-row-name">Tablets</span>
              <span class="dept-row-desc">A canvas for ideas — and the work that follows.</span>
            </div>
            <span class="dept-row-count">34 items</span>
            <div class="dept-row-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
                stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
            <div class="dept-row-img"><img src={imgUrl("/images/mp51zp5y-tab.jpg")} alt="Tablets"></div>
          </a>

          <a href="#" class="dept-row">
            <span class="dept-num">04</span>
            <div class="dept-info">
              <span class="dept-row-name">Smartwatches</span>
              <span class="dept-row-desc">Time, tracked. Notifications, tamed.</span>
            </div>
            <span class="dept-row-count">19 items</span>
            <div class="dept-row-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
                stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
            <div class="dept-row-img"><img src={imgUrl("/images/mp51zozp-smartwatch.jpg")} alt="Smartwatches"></div>
          </a>

          <a href="#" class="dept-row">
            <span class="dept-num">05</span>
            <div class="dept-info">
              <span class="dept-row-name">Cameras</span>
              <span class="dept-row-desc">Mirrorless, manual, made for the moment.</span>
            </div>
            <span class="dept-row-count">16 items</span>
            <div class="dept-row-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
                stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
            <div class="dept-row-img"><img src={imgUrl("/images/mp51zozf-camera.jpg")} alt="Cameras"></div>
          </a>

          <a href="#" class="dept-row">
            <span class="dept-num">06</span>
            <div class="dept-info">
              <span class="dept-row-name">Smartphones</span>
              <span class="dept-row-desc">Flagships, foldables and the future in your pocket.</span>
            </div>
            <span class="dept-row-count">22 items</span>
            <div class="dept-row-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
                stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </div>
            <div class="dept-row-img"><img src={imgUrl("/images/mp51zozm-smartphone.jpg")} alt="Smartphones"></div>
          </a>

        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
     PRODUCT SHOWCASE
============================================================ -->
