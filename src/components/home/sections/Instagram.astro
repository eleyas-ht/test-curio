---
import { INSTAGRAM, type InstagramPost } from '~/config/instagram';
import { fetchInstagramPosts } from '~/lib/instagram';

let posts: InstagramPost[] = [];

if (INSTAGRAM.mode === 'api') {
  const media = await fetchInstagramPosts(INSTAGRAM.postCount);
  if (media.length) {
    posts = media.map(m => ({
      image: m.thumbnail_url ?? m.media_url,
      alt: m.caption ? m.caption.slice(0, 100) : '',
      href: m.permalink,
    }));
  } else {
    // API unavailable or token not set — fall back to custom posts
    posts = INSTAGRAM.customPosts;
  }
} else {
  posts = INSTAGRAM.customPosts;
}

const igSvgPath = 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z';
---
  <section class="section-instagram">
    <div class="container">
      <div class="instagram-head">
        <div class="insta-head-left">
          <div class="insta-head-icon">
            <svg viewBox="0 0 24 24"><path d={igSvgPath} /></svg>
          </div>
          <div class="insta-head-text">
            <span class="insta-head-label">Follow us on Instagram</span>
            <span class="insta-head-handle">{INSTAGRAM.handle}</span>
          </div>
        </div>
        <a href={INSTAGRAM.profileUrl} target="_blank" rel="noopener noreferrer" class="insta-follow">Follow on Instagram</a>
      </div>

      <div class="insta-posts-wrap">
        <div class="insta-posts" id="insta-posts">
          {posts.map(post => (
            <div class="insta-post">
              {post.href ? (
                <a href={post.href} target="_blank" rel="noopener noreferrer" aria-label={`View Instagram post: ${post.alt || INSTAGRAM.handle}`}>
                  <img src={post.image} alt={post.alt} loading="lazy" />
                </a>
              ) : (
                <img src={post.image} alt={post.alt} loading="lazy" />
              )}
              <div class="insta-ig-badge"><svg viewBox="0 0 24 24"><path d={igSvgPath} /></svg></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

