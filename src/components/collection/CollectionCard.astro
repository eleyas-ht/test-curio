---
// ============================================================
//  CollectionCard — editorial promo-card style.
//  Full-bleed image, cocoa gradient, serif title in warm-white,
//  clay CTA with arrow. Links to the collection PLP.
//  Uses .promo-card classes from editorial.css (globally available).
// ============================================================
import type { Collection } from '~/lib/shopify/types';

interface Props {
  collection: Collection;
  index?: number;
  count?: number;
  class?: string;
}
const { collection, index, count, class: className = '' } = Astro.props;
const displayImage = collection.image ?? collection.firstProductImage ?? null;
const hasImage = !!displayImage?.url;
---

<a
  href={`/collections/${collection.handle}`}
  class={`promo-card ${className}`}
  aria-label={`Browse ${collection.title} collection`}
>
  {hasImage ? (
    <img
      src={displayImage!.url}
      alt={displayImage!.altText ?? collection.title}
      loading="lazy"
      class="promo-card-img"
    />
  ) : (
    <div class="promo-card-placeholder">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="44" height="44">
        <rect x="3" y="3" width="7" height="7" rx="1" />
        <rect x="14" y="3" width="7" height="7" rx="1" />
        <rect x="3" y="14" width="7" height="7" rx="1" />
        <rect x="14" y="14" width="7" height="7" rx="1" />
      </svg>
    </div>
  )}

  <div class="promo-overlay"></div>

  {/* Collection number badge — top left */}
  {index != null && (
    <span class="promo-badge">No. {String(index + 1).padStart(2, '0')}</span>
  )}

  {/* Product count — top right */}
  {count != null && (
    <span class="promo-count">{count} pieces</span>
  )}

  {/* Content overlay — bottom */}
  <div class="promo-body">
    <p class="promo-cat">Collection</p>
    <h3 class="promo-title">{collection.title}</h3>
    {collection.description && (
      <p class="promo-desc">{collection.description}</p>
    )}
    <span class="promo-cta">
      Explore
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </span>
  </div>
</a>

<style>
  /* Placeholder when no image is available */
  .promo-card-placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: var(--cream-deep);
    color: var(--sand-deep);
  }

  /* Product count badge — top right */
  .promo-count {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 2;
    font-family: var(--font-sans);
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--warm-white);
    background: rgba(42, 33, 28, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 5px 11px;
    border-radius: var(--r-pill);
    border: 1px solid rgba(255, 252, 247, 0.18);
  }

  /* Description snippet — truncated to 2 lines */
  .promo-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.55;
    color: rgba(255, 252, 247, 0.62);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
