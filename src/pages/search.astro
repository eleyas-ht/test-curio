---
// Search results — all result types (products, pages, articles), tab navigation.
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProductFeatCard from '~/components/product/ProductFeatCard.astro';
import '~/styles/pages/shop.css';
import { searchProducts, searchContent } from '~/lib/shopify';
import type { ProductCard } from '~/lib/shopify/types';
import type { PageResult, ArticleResult } from '~/lib/shopify/services/search';

const url = Astro.url;
const q = (url.searchParams.get('q') ?? '').trim();
const type = (url.searchParams.get('type') ?? 'products') as 'products' | 'pages' | 'articles';
const after = url.searchParams.get('after') ?? undefined;
const before = url.searchParams.get('before') ?? undefined;

// Tab-aware parallel fetch: full results for active tab, count-only (pageSize:1) for others.
let products: ProductCard[] = [];
let productTotal = 0;
let productHasNext = false;
let productEndCursor: string | null = null;
let productHasPrev = false;
let productStartCursor: string | null = null;

let pages: PageResult[] = [];
let pageTotal = 0;
let pageHasNext = false;
let pageEndCursor: string | null = null;

let articles: ArticleResult[] = [];
let articleTotal = 0;
let articleHasNext = false;
let articleEndCursor: string | null = null;

if (q) {
  try {
    const [pResult, pgResult, arResult] = await Promise.all([
      searchProducts({
        query: q,
        pageSize: type === 'products' ? 24 : 1,
        after: type === 'products' ? after : undefined,
        before: type === 'products' ? before : undefined,
      }),
      searchContent<PageResult>({ query: q, type: 'PAGE', pageSize: type === 'pages' ? 24 : 1, after: type === 'pages' ? after : undefined }),
      searchContent<ArticleResult>({ query: q, type: 'ARTICLE', pageSize: type === 'articles' ? 24 : 1, after: type === 'articles' ? after : undefined }),
    ]);

    productTotal = pResult.totalCount;
    productHasNext = pResult.pageInfo?.hasNextPage ?? false;
    productEndCursor = pResult.pageInfo?.endCursor ?? null;
    productHasPrev = pResult.pageInfo?.hasPreviousPage ?? false;
    productStartCursor = pResult.pageInfo?.startCursor ?? null;
    if (type === 'products') products = pResult.items;

    pageTotal = pgResult.totalCount;
    pageHasNext = pgResult.hasNextPage;
    pageEndCursor = pgResult.endCursor ?? null;
    if (type === 'pages') pages = pgResult.items;

    articleTotal = arResult.totalCount;
    articleHasNext = arResult.hasNextPage;
    articleEndCursor = arResult.endCursor ?? null;
    if (type === 'articles') articles = arResult.items;
  } catch (err) {
    console.error('[search] load failed:', (err as Error).message);
  }
}

function tabUrl(t: string, extra?: string) {
  const p = new URLSearchParams({ q, type: t });
  if (extra) p.set('after', extra);
  return `/search?${p.toString()}`;
}

function prevUrl() {
  const p = new URLSearchParams({ q, type });
  if (productHasPrev && productStartCursor) p.set('before', productStartCursor);
  return `/search?${p.toString()}`;
}

function nextUrl(cursor: string | null) {
  if (!cursor) return null;
  return tabUrl(type, cursor);
}

const totalForType = type === 'products' ? productTotal : type === 'pages' ? pageTotal : articleTotal;
const hasNextForType = type === 'products' ? productHasNext : type === 'pages' ? pageHasNext : articleHasNext;
const endCursorForType = type === 'products' ? productEndCursor : type === 'pages' ? pageEndCursor : articleEndCursor;
---

<BaseLayout title={q ? `Search · ${q}` : 'Search'} description="Search the full catalogue.">
  <style>
    /* ── Search page layout ── */
    .srp { padding: 40px 0 110px; }

    .srp-breadcrumb {
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: var(--muted); margin-bottom: 34px;
    }
    .srp-breadcrumb a { color: var(--muted); transition: color 200ms; }
    .srp-breadcrumb a:hover { color: var(--clay); }
    .srp-bc-sep { color: var(--sand-deep); }

    /* Header */
    .srp-head {
      display: flex; justify-content: space-between; align-items: flex-end;
      gap: 48px; padding-bottom: 36px;
      border-bottom: 1px solid var(--sand); margin-bottom: 30px;
    }
    .srp-eyebrow {
      display: inline-flex; align-items: center; gap: 9px;
      font-size: 12px; font-weight: 600; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--clay); margin-bottom: 18px;
    }
    .srp-eyebrow-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--clay); }
    .srp-title {
      font-size: clamp(40px, 5vw, 72px); font-weight: 400;
      line-height: 0.98; letter-spacing: -0.03em; color: var(--ink);
    }
    .srp-title em { font-style: italic; color: var(--clay); }
    .srp-sub {
      margin-top: 18px; max-width: 480px;
      font-size: 16px; line-height: 1.7; color: var(--muted);
    }

    /* Inline search form */
    .srp-form {
      display: flex; gap: 10px; align-items: center; flex-shrink: 0;
    }
    .srp-input {
      min-width: 220px; padding: 11px 16px;
      border: 1px solid var(--sand-deep); border-radius: var(--r-md);
      background: var(--warm-white); font-size: 14px; color: var(--ink);
      transition: border-color 200ms;
    }
    .srp-input:focus { outline: none; border-color: var(--clay); }

    /* Tabs */
    .srp-tabs {
      display: flex; gap: 4px; margin-bottom: 28px;
      border-bottom: 1px solid var(--sand);
    }
    .srp-tab {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 10px 18px; font-size: 13.5px; font-weight: 500;
      color: var(--muted); border-bottom: 2px solid transparent;
      margin-bottom: -1px; transition: color 200ms, border-color 200ms;
      text-decoration: none;
    }
    .srp-tab:hover { color: var(--ink); }
    .srp-tab.active { color: var(--ink); border-bottom-color: var(--clay); }
    .srp-tab-count {
      min-width: 20px; height: 20px; padding: 0 6px;
      border-radius: var(--r-pill); background: var(--cream-deep);
      font-size: 11px; font-weight: 700; color: var(--muted);
      display: inline-flex; align-items: center; justify-content: center;
    }
    .srp-tab.active .srp-tab-count {
      background: var(--clay); color: #fff;
    }

    /* Grid */
    .srp-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 30px 22px;
    }
    @media (max-width: 1100px) { .srp-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 860px)  { .srp-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px)  { .srp-grid { grid-template-columns: 1fr 1fr; gap: 20px 12px; } }

    /* Page / Article list */
    .srp-list { display: flex; flex-direction: column; gap: 1px; }
    .srp-item {
      display: flex; align-items: flex-start; gap: 20px;
      padding: 20px 0; border-bottom: 1px solid var(--sand);
      text-decoration: none; transition: background 200ms;
    }
    .srp-item:first-child { border-top: 1px solid var(--sand); }
    .srp-item:hover .srp-item-title { color: var(--clay-deep); }
    .srp-item-thumb {
      width: 80px; height: 60px; flex-shrink: 0;
      border-radius: var(--r-md); overflow: hidden;
      background: var(--cream-deep);
      border: 1px solid var(--sand);
    }
    .srp-item-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .srp-item-thumb-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
    }
    .srp-item-thumb-placeholder svg { width: 22px; height: 22px; color: var(--sand-deep); }
    .srp-item-body { flex: 1; min-width: 0; }
    .srp-item-meta {
      font-size: 11px; font-weight: 600; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--clay); margin-bottom: 5px;
    }
    .srp-item-title {
      font-family: var(--font-serif); font-size: 18px; font-weight: 500;
      color: var(--ink); line-height: 1.25; margin-bottom: 6px;
      transition: color 200ms;
    }
    .srp-item-excerpt {
      font-size: 14px; color: var(--muted); line-height: 1.6;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .srp-item-date { font-size: 12px; color: var(--muted-light); margin-top: 6px; }

    /* Empty */
    .srp-empty { text-align: center; padding: 80px 20px; }
    .srp-empty svg { width: 44px; height: 44px; color: var(--sand-deep); margin: 0 auto 18px; }
    .srp-empty h3 { font-size: 24px; margin-bottom: 10px; color: var(--ink); }
    .srp-empty p { max-width: 400px; margin: 0 auto 22px; color: var(--muted); }

    /* Pagination */
    .srp-pagination {
      display: flex; justify-content: center; align-items: center;
      gap: 12px; margin-top: 60px;
    }
    .srp-page-btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 11px 26px; border: 1px solid var(--ink);
      border-radius: var(--r-pill); font-size: 14px; font-weight: 500;
      color: var(--ink); text-decoration: none;
      transition: background 200ms, color 200ms;
    }
    .srp-page-btn:hover { background: var(--ink); color: var(--warm-white); }
    .srp-page-info { font-size: 13px; color: var(--muted); }

    @media (max-width: 860px) {
      .srp-head { flex-direction: column; align-items: flex-start; gap: 24px; }
      .srp-form { width: 100%; }
      .srp-input { flex: 1; }
    }
  </style>

  <main class="srp">
    <div class="container">
      {/* Breadcrumb */}
      <nav class="srp-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="srp-bc-sep">/</span>
        <span aria-current="page">Search</span>
      </nav>

      {/* Page header */}
      <header class="srp-head">
        <div>
          <span class="srp-eyebrow"><span class="srp-eyebrow-dot"></span>The Edit · Search</span>
          <h1 class="srp-title" set:html={q ? `Results for <em>"${q}"</em>` : 'Search the <em>catalogue</em>'} />
          {q && (
            <p class="srp-sub">
              {totalForType} {type} found
              {totalForType !== productTotal + pageTotal + articleTotal
                ? ` · ${productTotal + pageTotal + articleTotal} total across all types`
                : ''}
            </p>
          )}
          {!q && (
            <p class="srp-sub">
              Find products, editorial articles, and guides across the full catalogue.
            </p>
          )}
        </div>
        <form class="srp-form" action="/search" method="get">
          <input type="hidden" name="type" value={type} />
          <input
            class="srp-input"
            type="search"
            name="q"
            value={q}
            placeholder="Search…"
            aria-label="Search query"
          />
          <button type="submit" class="btn-primary">Search</button>
        </form>
      </header>

      {q && (
        <>
          {/* Tab navigation */}
          <nav class="srp-tabs" aria-label="Result types">
            <a
              href={tabUrl('products')}
              class={`srp-tab${type === 'products' ? ' active' : ''}`}
              aria-current={type === 'products' ? 'page' : undefined}
            >
              Products
              <span class="srp-tab-count">{productTotal}</span>
            </a>
            <a
              href={tabUrl('pages')}
              class={`srp-tab${type === 'pages' ? ' active' : ''}`}
              aria-current={type === 'pages' ? 'page' : undefined}
            >
              Pages
              <span class="srp-tab-count">{pageTotal}</span>
            </a>
            <a
              href={tabUrl('articles')}
              class={`srp-tab${type === 'articles' ? ' active' : ''}`}
              aria-current={type === 'articles' ? 'page' : undefined}
            >
              Articles
              <span class="srp-tab-count">{articleTotal}</span>
            </a>
          </nav>

          {/* Products tab */}
          {type === 'products' && (
            products.length > 0 ? (
              <>
                <div class="srp-grid">
                  {products.map((p) => <ProductFeatCard product={p} actions />)}
                </div>
                {(productHasPrev || productHasNext) && (
                  <div class="srp-pagination">
                    {productHasPrev && (
                      <a href={prevUrl()} class="srp-page-btn">
                        ← Previous
                      </a>
                    )}
                    <span class="srp-page-info">Showing {products.length} of {productTotal}</span>
                    {productHasNext && endCursorForType && (
                      <a href={nextUrl(endCursorForType)} class="srp-page-btn">
                        Next →
                      </a>
                    )}
                  </div>
                )}
              </>
            ) : (
              <div class="srp-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <circle cx="11" cy="11" r="7" />
                  <path d="m20 20-3.5-3.5" />
                </svg>
                <h3>No products matched "{q}"</h3>
                <p>Try a different term or browse the full catalogue.</p>
                <a class="btn-primary" href="/products">Browse all products</a>
              </div>
            )
          )}

          {/* Pages tab */}
          {type === 'pages' && (
            pages.length > 0 ? (
              <>
                <ul class="srp-list" role="list">
                  {pages.map((p) => (
                    <li>
                      <a href={`/pages/${p.handle}`} class="srp-item">
                        <div class="srp-item-thumb">
                          <div class="srp-item-thumb-placeholder">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                              <polyline points="14,2 14,8 20,8" />
                            </svg>
                          </div>
                        </div>
                        <div class="srp-item-body">
                          <p class="srp-item-meta">Page</p>
                          <h3 class="srp-item-title">{p.title}</h3>
                          {p.bodySummary && <p class="srp-item-excerpt">{p.bodySummary}</p>}
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
                {pageHasNext && pageEndCursor && (
                  <div class="srp-pagination">
                    <a href={tabUrl('pages', pageEndCursor)} class="srp-page-btn">
                      Load more →
                    </a>
                  </div>
                )}
              </>
            ) : (
              <div class="srp-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14,2 14,8 20,8" />
                </svg>
                <h3>No pages matched "{q}"</h3>
                <p>Try a different search term.</p>
              </div>
            )
          )}

          {/* Articles tab */}
          {type === 'articles' && (
            articles.length > 0 ? (
              <>
                <ul class="srp-list" role="list">
                  {articles.map((a) => (
                    <li>
                      <a href={`/blogs/${a.blog.handle}/${a.handle}`} class="srp-item">
                        <div class="srp-item-thumb">
                          {a.image ? (
                            <img src={a.image.url} alt={a.image.altText ?? a.title} loading="lazy" />
                          ) : (
                            <div class="srp-item-thumb-placeholder">
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                              </svg>
                            </div>
                          )}
                        </div>
                        <div class="srp-item-body">
                          <p class="srp-item-meta">{a.blog?.title ?? 'Article'}</p>
                          <h3 class="srp-item-title">{a.title}</h3>
                          {a.excerpt && <p class="srp-item-excerpt">{a.excerpt}</p>}
                          {a.publishedAt && (
                            <p class="srp-item-date">
                              {new Date(a.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                            </p>
                          )}
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
                {articleHasNext && articleEndCursor && (
                  <div class="srp-pagination">
                    <a href={tabUrl('articles', articleEndCursor)} class="srp-page-btn">
                      Load more →
                    </a>
                  </div>
                )}
              </>
            ) : (
              <div class="srp-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                  <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                </svg>
                <h3>No articles matched "{q}"</h3>
                <p>Try a different search term or browse the journal.</p>
              </div>
            )
          )}
        </>
      )}

      {/* No query — prompt state */}
      {!q && (
        <div class="srp-empty">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
            <circle cx="11" cy="11" r="7" />
            <path d="m20 20-3.5-3.5" />
          </svg>
          <h3>Start typing to search</h3>
          <p>Search the full range of products, pages, and articles from the form above.</p>
          <a class="btn-primary" href="/products">Browse all products</a>
        </div>
      )}
    </div>
  </main>
</BaseLayout>
