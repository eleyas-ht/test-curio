---
// ============================================================
//  /account/addresses — address book management
// ============================================================
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import {
  createCustomerClient,
  CUSTOMER_ADDRESSES_QUERY,
  getPublicOrigin,
  NotAuthenticatedError,
} from '~/lib/shopify/customer';
import type { CustomerAddressesResult, CustomerAddress } from '~/lib/shopify/customer';

export const prerender = false;

const client = createCustomerClient(Astro.cookies, getPublicOrigin(Astro.request, Astro.url));

if (!client.isLoggedIn()) {
  return Astro.redirect('/account/login?return_to=/account/addresses');
}

let addresses: CustomerAddress[] = [];
let defaultAddressId: string | null = null;
let error: string | null = null;
const flash = Astro.url.searchParams.get('success');

try {
  const data = await client.query<CustomerAddressesResult>(CUSTOMER_ADDRESSES_QUERY, { first: 20 });
  addresses = data.customer?.addresses?.nodes ?? [];
  defaultAddressId = data.customer?.defaultAddress?.id ?? null;
} catch (err) {
  if (err instanceof NotAuthenticatedError) {
    return Astro.redirect('/account/login?return_to=/account/addresses');
  }
  error = (err as Error).message;
}

function addrLines(a: CustomerAddress): string[] {
  return [
    [a.firstName, a.lastName].filter(Boolean).join(' '),
    a.company,
    a.address1,
    a.address2,
    [a.city, a.province].filter(Boolean).join(', ') + (a.zip ? ` ${a.zip}` : ''),
    a.country,
  ].filter((l): l is string => Boolean(l));
}

const encodeId = (id: string) =>
  btoa(id).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
---

<BaseLayout title="Addresses">
  <PageHeader eyebrow="My account" title="Address *book*" />

  <div class="container account-section">
    <nav class="account-nav">
      <a href="/account" class="account-nav-link">Overview</a>
      <a href="/account/orders" class="account-nav-link">Orders</a>
      <a href="/account/profile" class="account-nav-link">Profile</a>
      <a href="/account/addresses" class="account-nav-link active" aria-current="page">Addresses</a>
      <a href="/account/logout" class="account-nav-link account-nav-link--logout">Sign out</a>
    </nav>

    {flash === 'added' && (
      <div class="flash flash--success">Address added successfully.</div>
    )}
    {flash === 'updated' && (
      <div class="flash flash--success">Address updated.</div>
    )}
    {flash === 'deleted' && (
      <div class="flash flash--success">Address removed.</div>
    )}
    {flash === 'default' && (
      <div class="flash flash--success">Default address updated.</div>
    )}

    {error && (
      <p class="account-alert">
        {error}
      </p>
    )}

    <div class="address-actions-bar">
      <p class="text-sm text-muted">
        {addresses.length === 0
          ? 'No addresses saved.'
          : `${addresses.length} address${addresses.length !== 1 ? 'es' : ''} saved.`}
      </p>
      <a href="/account/addresses/new" class="btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14" />
        </svg>
        Add address
      </a>
    </div>

    {addresses.length === 0 ? (
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" width="44" height="44" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <p>You haven't saved any addresses yet.</p>
        <a href="/account/addresses/new" class="btn-outline">Add your first address</a>
      </div>
    ) : (
      <div class="address-grid">
        {addresses.map((addr) => {
          const isDefault = addr.id === defaultAddressId;
          const encodedId = encodeId(addr.id);
          return (
            <div class={`address-card${isDefault ? ' address-card--default' : ''}`}>
              {isDefault && <span class="default-badge">Default</span>}

              <address class="not-italic text-sm text-muted leading-relaxed">
                {addrLines(addr).map((line, i) => (
                  <Fragment>
                    {line}
                    {i < addrLines(addr).length - 1 && <br />}
                  </Fragment>
                ))}
              </address>

              <div class="address-card-actions">
                <a href={`/account/addresses/${encodedId}`} class="addr-action-link">Edit</a>

                {!isDefault && (
                  <form method="post" action="/api/account/addresses/default" class="inline">
                    <input type="hidden" name="addressId" value={addr.id} />
                    <button type="submit" class="addr-action-btn">Set as default</button>
                  </form>
                )}

                <form method="post" action="/api/account/addresses/delete" class="inline"
                  onsubmit="return confirm('Remove this address?')">
                  <input type="hidden" name="addressId" value={addr.id} />
                  <button type="submit" class="addr-action-btn addr-action-btn--danger">Remove</button>
                </form>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  /* ── Page section vertical padding ───────────────────────── */
  .account-section {
    padding-top: 0;
    padding-bottom: 64px;
  }
  @media (max-width: 640px) {
    .account-section { padding-top: 0; padding-bottom: 48px; }
  }

  /* ── Alert ────────────────────────────────────────────────── */
  .account-alert {
    margin-bottom: 28px;
    padding: 12px 16px;
    border-radius: var(--radius-md);
    font-size: 14px;
    line-height: 1.5;
    background: rgba(179, 64, 31, 0.05);
    border: 1px solid rgba(179, 64, 31, 0.3);
    color: var(--color-danger);
  }

  /* ── Account nav ──────────────────────────────────────────── */
  .account-nav {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--color-sand-deep);
    overflow-x: auto;
    scrollbar-width: none;
    margin-bottom: 40px;
  }
  .account-nav::-webkit-scrollbar { display: none; }
  .account-nav-link {
    display: inline-block;
    padding: 10px 18px 10px 0;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-muted);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    white-space: nowrap;
    text-decoration: none;
    transition: color 180ms, border-color 180ms;
  }
  .account-nav-link:hover { color: var(--color-ink); }
  .account-nav-link.active { color: var(--color-ink); border-bottom-color: var(--color-clay); }
  .account-nav-link--logout { margin-left: auto; padding-right: 0; color: var(--color-muted-light); }
  .account-nav-link--logout:hover { color: var(--color-danger); }

  /* ── Flash messages ───────────────────────────────────────── */
  .flash {
    padding: 12px 16px;
    border-radius: var(--radius-md);
    font-size: 14px;
    margin-bottom: 28px;
  }
  .flash--success { background: #d1fae5; color: var(--color-success); border: 1px solid #6ee7b7; }

  /* ── Actions bar ──────────────────────────────────────────── */
  .address-actions-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .address-actions-bar p {
    font-size: 14px;
    color: var(--color-muted);
  }

  /* ── Buttons ──────────────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 11px 22px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--color-cocoa);
    color: var(--color-warm-white);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 180ms;
  }
  .btn-primary:hover { background: var(--color-clay); }

  .btn-outline {
    display: inline-block;
    padding: 10px 24px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1.5px solid var(--color-sand-deep);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    text-decoration: none;
    transition: background 180ms, border-color 180ms;
  }
  .btn-outline:hover { background: var(--color-sand); border-color: var(--color-clay); }

  /* ── Empty state ──────────────────────────────────────────── */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 64px 24px;
    text-align: center;
    color: var(--color-muted);
    font-size: 14px;
    line-height: 1.6;
    background: var(--color-warm-white);
    border: 1px solid var(--color-sand-deep);
    border-radius: var(--radius-lg);
  }

  /* ── Address grid ─────────────────────────────────────────── */
  .address-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 600px) { .address-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 900px) { .address-grid { grid-template-columns: 1fr 1fr 1fr; } }

  .address-card {
    background: var(--color-warm-white);
    border: 1px solid var(--color-sand-deep);
    border-radius: var(--radius-lg);
    padding: 24px;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .address-card--default { border-color: var(--color-clay); }

  .default-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-clay);
    background: rgba(154, 107, 79, 0.08);
    border: 1px solid rgba(154, 107, 79, 0.25);
    padding: 3px 9px;
    border-radius: var(--radius-pill);
    margin-bottom: 14px;
    width: fit-content;
  }

  .address-card address {
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.85;
    font-style: normal;
    flex: 1;
  }

  .address-card-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--color-sand);
    flex-wrap: wrap;
  }

  .addr-action-link,
  .addr-action-btn {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-clay);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: none;
    transition: color 160ms;
  }
  .addr-action-link:hover,
  .addr-action-btn:hover { color: var(--color-clay-deep); }
  .addr-action-btn--danger { color: var(--color-muted-light); }
  .addr-action-btn--danger:hover { color: var(--color-danger); }

  .inline { display: inline; }
</style>
