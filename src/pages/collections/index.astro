---
// Collections index — editorial page with a promo-card grid followed by
// the department TOC spread. Wired to live Shopify collections.
import BaseLayout from '~/layouts/BaseLayout.astro';
import CollectionCard from '~/components/collection/CollectionCard.astro';
import '~/styles/pages/shop.css';
import { getAllCollections } from '~/lib/shopify';
import { buyerIpFrom } from '~/lib/shopify/buyer-ip';
import { countryFrom } from '~/lib/shopify/country';
import type { Collection } from '~/lib/shopify/types';

let collections: Collection[] = [];
try {
  collections = await getAllCollections(50, { buyerIp: buyerIpFrom(Astro.request), country: countryFrom(Astro.request) });
} catch (err) {
  console.error('[collections] load failed:', (err as Error).message);
}
---

<BaseLayout
  title="Collections"
  description="Shop the full range by collection — curated edits for every part of your setup."
>

  <!-- ── Page header ─────────────────────────────────────── -->
  <section class="coll-page-head">
    <div class="container">

      <nav class="shop-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="shop-bc-sep">/</span>
        <span aria-current="page">Collections</span>
      </nav>

      <div class="shop-head" style="padding-bottom:0;border-bottom:none;margin-bottom:0;">
        <div class="shop-head-left">
          <span class="shop-eyebrow">
            <span class="shop-eyebrow-dot"></span>
            The Edit · Curated Collections
          </span>
          <h1 class="shop-title">Browse by <em>collection</em>.</h1>
          <p class="shop-sub">
            Curated edits for every part of your setup — each one tested and chosen by our editors
            with care. No filler, no noise.
          </p>
        </div>
        <div class="shop-head-stats">
          <div class="shop-stat">
            <span class="shop-stat-num">{collections.length || '—'}</span>
            <span class="shop-stat-label">Collections</span>
          </div>
          <div class="shop-stat">
            <span class="shop-stat-num">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:24px;height:24px;margin:0 auto;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
              </svg>
            </span>
            <span class="shop-stat-label">Editor curated</span>
          </div>
          <div class="shop-stat">
            <span class="shop-stat-num">
              <a href="/products" class="coll-stat-link">→</a>
            </span>
            <span class="shop-stat-label">Shop all</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Collection card grid ────────────────────────────── -->
  <section class="coll-grid-section">
    <div class="container">

      {collections.length > 0 ? (
        <div class="promo-grid">
          {collections.map((c, i) => (
            <CollectionCard collection={c} index={i} />
          ))}
        </div>
      ) : (
        <div class="shop-empty">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
          </svg>
          <h3>No collections yet</h3>
          <p>We couldn't load any collections right now. Try again shortly.</p>
          <a href="/products" class="btn-primary">Browse all products</a>
        </div>
      )}

    </div>
  </section>


</BaseLayout>

<style>
  /* ── Page header ── */
  .coll-page-head {
    padding: 40px 0 60px;
    background: var(--cream);
    border-bottom: 1px solid var(--sand);
  }

  .coll-stat-link {
    font-family: var(--font-serif);
    font-size: 26px;
    color: var(--clay);
    display: block;
    line-height: 1;
  }

  /* ── Card grid section ── */
  .coll-grid-section {
    padding: 72px 0 90px;
    background: var(--cream-deep);
    border-bottom: 1px solid var(--sand);
  }

</style>
