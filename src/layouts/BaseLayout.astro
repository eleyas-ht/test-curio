---
// ============================================================
//  BaseLayout — html shell shared by every page. Mounts the
//  global cart drawer + mobile bottom nav islands once.
// ============================================================
import '~/styles/global.css';
import '~/styles/editorial.css';
import { SITE } from '~/config/site';
import Announcement from '~/components/layout/Announcement.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import CartDrawer from '~/components/layout/CartDrawer.astro';
import WishlistDrawer from '~/components/layout/WishlistDrawer.astro';
import QuickView from '~/components/product/QuickView.astro';
import CompareBar from '~/components/layout/CompareBar.astro';
import BackToTop from '~/components/layout/BackToTop.astro';
import NewsletterPopup from '~/components/layout/NewsletterPopup.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noFooter?: boolean;
}

const { title, description = SITE.description, image, noFooter = false } = Astro.props;

const pageTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.url.origin).href;
const ogImage = image ?? new URL('/images/og-default.jpg', Astro.url.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    {/* Fonts — preconnect then load Newsreader (serif display, italics) · Inter (body/UI) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300..700;1,6..72,300..600&family=Inter:wght@300;400;500;600;700&display=swap"
    />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#2a211c" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>

  <body>
    <Announcement />
    <Header />

    <main id="main">
      <slot />
    </main>

    {!noFooter && <Footer />}

    {/* Cart drawer + wishlist drawer + quick-view modal (hidden until opened) */}
    <CartDrawer />
    <WishlistDrawer />
    <QuickView />
    {/* Compare bar (slides up from bottom when products are queued) */}
    <CompareBar />
    <BackToTop />
    {/* Newsletter popup — slides up from bottom-left after configured delay */}
    <NewsletterPopup />
  </body>
</html>
